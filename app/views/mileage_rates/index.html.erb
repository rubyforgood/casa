<% content_for :page_title, "Mileage Rates" %>
<%# mileage_rates#index on the casa_app shell. Org-settings list of reimbursement rates.
    Reached from the admin sidebar; matches the sibling org-settings tables (plain Yes/No
    active, brand Edit link). No delete — rates are edited, never removed. %>
<% card = "rounded-2xl border border-slate-200 bg-white shadow-sm" %>
<% th = "px-3 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500" %>
<% td = "px-3 py-3 text-sm text-slate-700 align-top" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Mileage Rates</h1>
        <p class="mt-1 text-sm text-slate-500">The per-mile reimbursement rate volunteers are paid for case-related driving.</p>
      </div>
      <%= link_to new_mileage_rate_path, class: button_classes(:primary) do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i> New mileage rate
      <% end %>
    </div>

    <% if @mileage_rates.any? %>
      <div class="<%= card %> overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200" id="mileage_rates">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="<%= th %>">Effective date</th>
                <th scope="col" class="<%= th %>">Amount</th>
                <th scope="col" class="<%= th %>">Active?</th>
                <th scope="col" class="<%= th %> text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @mileage_rates.each do |mileage_rate| %>
                <tr>
                  <td class="<%= td %> whitespace-nowrap"><%= I18n.l(mileage_rate.effective_date, format: :full, default: nil) %></td>
                  <td class="<%= td %>"><%= number_to_currency(mileage_rate.amount) %></td>
                  <td class="<%= td %>"><%= mileage_rate.is_active? ? "Yes" : "No" %></td>
                  <td class="<%= td %> text-right">
                    <%= link_to "Edit", edit_mileage_rate_path(mileage_rate), class: "font-medium text-brand-600 hover:text-brand-700" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="<%= card %> px-6 py-16 text-center">
        <div class="mx-auto mb-4 grid h-12 w-12 place-items-center rounded-full bg-slate-100 text-slate-400"><i class="bi bi-car-front text-xl" aria-hidden="true"></i></div>
        <h2 class="text-base font-semibold text-slate-900">No mileage rates yet</h2>
        <p class="mt-1 text-sm text-slate-500">Add a rate so volunteers can be reimbursed for driving.</p>
      </div>
    <% end %>
  </div>
</div>
