<%# casa_app new/edit form for a mileage rate. Locals: mileage_rate, title. %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% check_class = "h-4 w-4 shrink-0 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= title %></h1>
    <div class="<%= card %>">
      <%= form_with model: mileage_rate, local: true, id: :new_mileage_rate, class: "space-y-5" do |form| %>
        <%= render "shared/form_errors", resource: mileage_rate %>
        <div>
          <%= form.label :effective_date, "Effective date", class: label_class %>
          <%= form.date_field :effective_date, value: mileage_rate.effective_date, class: input_class %>
        </div>
        <div>
          <%= form.label :amount, "Amount", class: label_class %>
          <%= form.number_field :amount, required: true, placeholder: "0.0", min: 0, step: 0.01, class: input_class, aria: {label: "Amount in US Dollars"} %>
        </div>
        <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= form.check_box :is_active, class: check_class %>
          <span>Currently active?</span>
        </label>
        <div>
          <%= form.submit "Save mileage rate", class: button_classes(:primary) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
