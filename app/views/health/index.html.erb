<%# Minimal, self-contained ops status page (rendered with layout: false). Deliberately
    inlines its styles so it still renders if the asset build is broken -- this is a health
    check. No app chrome, no nav, no cross-org data. %>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CASA service status</title>
    <style>
      body { margin: 0; min-height: 100vh; display: grid; place-items: center; background: #f8fafc; color: #0f172a; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
      main { text-align: center; padding: 2rem 2.5rem; }
      h1 { font-size: 1.25rem; margin: 0 0 .5rem; font-weight: 700; }
      p { margin: 0; color: #475569; font-size: .875rem; }
      .dot { display: inline-block; width: .625rem; height: .625rem; border-radius: 9999px; background: #059669; margin-right: .5rem; vertical-align: middle; }
    </style>
  </head>
  <body>
    <main>
      <h1><span class="dot" aria-hidden="true"></span>CASA is running</h1>
      <% if (deploy = Health.instance.latest_deploy_time) %>
        <p>Latest deploy <%= time_ago_in_words(deploy) %> ago (<%= deploy.utc.iso8601 %>)</p>
      <% end %>
    </main>
  </body>
</html>
