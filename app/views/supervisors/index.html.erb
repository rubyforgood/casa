<% content_for :page_title, "Supervisors" %>
<%# supervisors#index on the casa_app shell. Bespoke Tailwind tables replacing the jQuery
    DataTable: a supervisor roster (with volunteer-contact stats), a "volunteers without
    supervisors" list, and a "CASA cases without court dates" list. Server-side status filter
    (auto-submit). #supervisors lives on the wrapper <div> (not the <table>) so dashboard.js's
    $('table#supervisors').DataTable(...) no longer matches and no serverSide table inits over
    the migrated markup. Hearing type / Judge columns are dropped: that data moved onto court
    dates in 2023, so it is always blank for court-date-less cases (see design.md). Spec hooks:
    #supervisors, .supervisor-filters, [data-stat]. %>
<% th = "px-4 py-3 text-left text-xs font-semibold text-slate-600 whitespace-nowrap align-top" %>
<% td = "px-4 py-3 text-sm text-slate-700 align-top" %>
<% pill = "inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium" %>
<% ghost = "inline-flex items-center gap-1.5 rounded-lg px-2 py-1 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" %>
<% chevron = "bi bi-chevron-down pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Supervisors</h1>
    <% if policy(Supervisor).create? %>
      <%= link_to new_supervisor_path, class: button_classes(:primary) do %><i class="bi bi-plus-lg" aria-hidden="true"></i> New supervisor<% end %>
    <% end %>
  </div>

  <%# Status filter (server-side, submits on change). %>
  <%= form_with url: supervisors_path, method: :get, data: {controller: "auto-submit", action: "change->auto-submit#submit"}, class: "supervisor-filters mb-5" do %>
    <div class="w-full max-w-[10rem]">
      <%= label_tag :status, "Status", class: "mb-1 block text-xs font-medium text-slate-500" %>
      <div class="relative">
        <%= select_tag :status, options_for_select([["Active", "active"], ["Inactive", "inactive"], ["All", "all"]], @status), class: "block w-full appearance-none rounded-lg border border-slate-300 bg-white py-2 pl-3 pr-9 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
        <i class="<%= chevron %>" aria-hidden="true"></i>
      </div>
    </div>
    <noscript><%= submit_tag "Filter", class: "#{button_classes(:primary)} mt-2" %></noscript>
  <% end %>

  <%# Supervisor roster. #supervisors is the spec hook (on the wrapper, not the <table>). %>
  <div id="supervisors" class="overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100">
            <th class="<%= th %>">Supervisor</th>
            <th class="<%= th %>">Volunteers</th>
            <th class="<%= th %>"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% if @supervisors.any? %>
            <% @supervisors.each do |supervisor| %>
              <% not_attempting = supervisor.no_attempt_for_two_weeks %>
              <% attempting = supervisor.active_volunteers - not_attempting %>
              <% transition = supervisor.volunteers_serving_transition_aged_youth %>
              <tr id="supervisor-<%= supervisor.id %>-information" class="hover:bg-slate-50/70">
                <td class="<%= td %>">
                  <div class="flex flex-wrap items-center gap-2">
                    <%= link_to formatted_name(supervisor.display_name).presence || supervisor.email, edit_supervisor_path(supervisor), class: "font-medium text-slate-800 hover:text-brand-700 hover:underline" %>
                    <% unless supervisor.active? %>
                      <span class="<%= pill %> bg-slate-100 text-slate-600"><i class="bi bi-dash-circle" aria-hidden="true"></i> Inactive</span>
                    <% end %>
                  </div>
                </td>
                <td class="<%= td %>">
                  <div class="flex flex-wrap items-center gap-1.5">
                    <% if attempting <= 0 && not_attempting <= 0 %>
                      <span class="text-slate-500" data-stat="no-volunteers">No assigned volunteers</span>
                    <% else %>
                      <% if attempting > 0 %>
                        <span class="<%= pill %> bg-emerald-50 text-emerald-700" data-stat="attempting" title="Volunteers attempting contact (within 2 weeks)"><i class="bi bi-check-circle" aria-hidden="true"></i> <%= attempting %> attempting</span>
                      <% end %>
                      <% if not_attempting > 0 %>
                        <span class="<%= pill %> bg-rose-50 text-rose-700" data-stat="not-attempting" title="Volunteers not attempting contact (within 2 weeks)"><i class="bi bi-exclamation-circle" aria-hidden="true"></i> <%= not_attempting %> not attempting</span>
                      <% end %>
                      <span class="<%= pill %> bg-slate-100 text-slate-600" data-stat="transition" title="Volunteers serving transition-aged youth"><i class="bi bi-mortarboard" aria-hidden="true"></i> <%= transition %> transition-aged</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <%= link_to edit_supervisor_path(supervisor), "aria-label": "Edit #{formatted_name(supervisor.display_name)}", class: ghost do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-4 py-14 text-center">
                <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-diagram-3 text-xl" aria-hidden="true"></i></div>
                <p class="mt-3 text-sm font-semibold text-slate-900">No supervisors found</p>
                <p class="mt-1 text-sm text-slate-500"><%= (@status == "active") ? "There are no active supervisors to show." : "Try a different status filter." %></p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Volunteers without supervisors. %>
  <section class="mt-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">Volunteers without supervisors</h2>
    <% if @available_volunteers.any? %>
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-100">
                <th class="<%= th %>">Volunteer</th>
                <th class="<%= th %>">Assigned cases</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% @available_volunteers.each do |volunteer| %>
                <tr class="hover:bg-slate-50/70">
                  <td class="<%= td %>"><%= link_to formatted_name(volunteer.display_name).presence || volunteer.email, edit_volunteer_path(volunteer), class: "font-medium text-slate-800 hover:text-brand-700 hover:underline" %></td>
                  <td class="<%= td %>"><%= safe_join(volunteer.casa_cases.map { |cc| link_to(cc.case_number, casa_case_path(cc), class: "text-brand-600 hover:text-brand-700 hover:underline") }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center text-sm text-slate-500">
        There are no active volunteers without supervisors to display here
      </div>
    <% end %>
  </section>

  <%# CASA cases without court dates. %>
  <section class="mt-8">
    <h2 class="mb-3 text-lg font-semibold text-slate-900">CASA cases without court dates</h2>

    <%# Desktop table (md+). %>
    <div data-test="cases-without-court-dates" class="hidden overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-sm md:block">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-100">
              <th class="<%= th %>">Case number</th>
              <th class="<%= th %>">Status</th>
              <th class="<%= th %>">Transition-aged youth</th>
              <th class="<%= th %>">Assigned to</th>
              <th class="<%= th %>"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% if @casa_cases.any? %>
              <% @casa_cases.each do |casa_case| %>
                <tr class="hover:bg-slate-50/70">
                  <td class="<%= td %>"><%= link_to casa_case.case_number, casa_case, class: "font-medium text-brand-600 hover:text-brand-700 hover:underline" %></td>
                  <td class="<%= td %>">
                    <% if casa_case.active? %>
                      <span class="<%= pill %> bg-emerald-50 text-emerald-700"><i class="bi bi-check-circle" aria-hidden="true"></i> Active</span>
                    <% else %>
                      <span class="<%= pill %> bg-slate-100 text-slate-600"><i class="bi bi-dash-circle" aria-hidden="true"></i> Inactive</span>
                    <% end %>
                  </td>
                  <td class="<%= td %>">
                    <% if casa_case.in_transition_age? %>
                      <span class="<%= pill %> bg-violet-50 text-violet-700">Yes</span>
                    <% else %>
                      <span class="text-slate-500">No</span>
                    <% end %>
                  </td>
                  <td class="<%= td %>">
                    <% if casa_case.active? %>
                      <% if current_user.volunteer? %>
                        <%= safe_join(casa_case.assigned_volunteers.map { |vol| tag.span(formatted_name(vol.display_name), class: "font-medium text-slate-800") }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %>
                      <% else %>
                        <%= safe_join(casa_case.assigned_volunteers.map { |vol| link_to(formatted_name(vol.display_name), edit_volunteer_path(vol), class: "font-medium text-slate-800 hover:text-brand-700 hover:underline") }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %>
                      <% end %>
                    <% else %>
                      <span class="text-slate-500">Case was deactivated on: <%= I18n.l(casa_case.updated_at, format: :standard, default: nil) %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-right whitespace-nowrap">
                    <div class="flex items-center justify-end gap-1">
                      <%= link_to casa_case_path(casa_case), class: ghost do %><i class="bi bi-eye" aria-hidden="true"></i> Detail view<% end %>
                      <%= link_to edit_casa_case_path(casa_case), "aria-label": "Edit #{casa_case.case_number}", class: ghost do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="px-4 py-10 text-center text-sm text-slate-500">All cases have court dates scheduled.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Mobile: stacked cards (below md). %>
    <div class="md:hidden">
      <% if @casa_cases.any? %>
        <ul class="space-y-3">
          <% @casa_cases.each do |casa_case| %>
            <li class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <%= link_to casa_case.case_number, casa_case, class: "text-base font-semibold text-brand-600 hover:text-brand-700" %>
                <%= link_to edit_casa_case_path(casa_case), "aria-label": "Edit #{casa_case.case_number}", class: "-mr-1 -mt-1 inline-flex flex-none items-center gap-1.5 rounded-lg px-2 py-1 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %><i class="bi bi-pencil" aria-hidden="true"></i>Edit<% end %>
              </div>
              <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-3">
                <div>
                  <dt class="text-xs text-slate-500">Status</dt>
                  <dd class="mt-0.5">
                    <% if casa_case.active? %>
                      <span class="<%= pill %> bg-emerald-50 text-emerald-700"><i class="bi bi-check-circle" aria-hidden="true"></i> Active</span>
                    <% else %>
                      <span class="<%= pill %> bg-slate-100 text-slate-600"><i class="bi bi-dash-circle" aria-hidden="true"></i> Inactive</span>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-xs text-slate-500">Transition-aged youth</dt>
                  <dd class="mt-0.5">
                    <% if casa_case.in_transition_age? %>
                      <span class="<%= pill %> bg-violet-50 text-violet-700">Yes</span>
                    <% else %>
                      <span class="text-sm text-slate-500">No</span>
                    <% end %>
                  </dd>
                </div>
                <div class="col-span-2">
                  <dt class="text-xs text-slate-500">Assigned to</dt>
                  <dd class="mt-0.5 text-sm text-slate-700">
                    <% if casa_case.active? %>
                      <% if current_user.volunteer? %>
                        <%= safe_join(casa_case.assigned_volunteers.map { |vol| tag.span(formatted_name(vol.display_name), class: "font-medium text-slate-800") }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %>
                      <% else %>
                        <%= safe_join(casa_case.assigned_volunteers.map { |vol| link_to(formatted_name(vol.display_name), edit_volunteer_path(vol), class: "font-medium text-slate-800 hover:text-brand-700 hover:underline") }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %>
                      <% end %>
                    <% else %>
                      <span class="text-slate-500">Case was deactivated on: <%= I18n.l(casa_case.updated_at, format: :standard, default: nil) %></span>
                    <% end %>
                  </dd>
                </div>
              </dl>
              <div class="mt-3">
                <%= link_to casa_case_path(casa_case), class: ghost do %><i class="bi bi-eye" aria-hidden="true"></i> Detail view<% end %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center text-sm text-slate-500">All cases have court dates scheduled.</div>
      <% end %>
    </div>
  </section>
</div>
