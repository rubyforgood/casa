<%# Supervisor status + activation controls (supervisor-specific twin; the volunteers page has
    its own volunteers/_manage_active). Deactivate keeps the UJS data-confirm (native
    window.confirm) that the :js spec drives with accept_confirm/dismiss_confirm — deliberately
    not the Dialog confirm, which those Capybara helpers can't operate. Title Case labels
    (Deactivate Supervisor, Activate supervisor, Resend Invitation, Change to Admin) are
    spec-locked. %>
<% pill = "inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium" %>
<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <h2 class="text-base font-semibold text-slate-900">Status</h2>

  <div class="mt-4">
    <% if user.active? %>
      <p class="flex flex-wrap items-center gap-2 text-sm text-slate-600">Supervisor is
        <span class="<%= pill %> bg-emerald-50 text-emerald-700"><i class="bi bi-check-circle" aria-hidden="true"></i> Active</span>
      </p>
    <% else %>
      <div role="alert" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        Supervisor was deactivated on: <%= user.decorate.formatted_updated_at %>
      </div>
    <% end %>

    <div class="mt-4 flex flex-wrap gap-2">
      <% if user.active? %>
        <% if current_user.casa_admin? && policy(user).deactivate? %>
          <%= link_to deactivate_supervisor_path(user), method: :patch, class: button_classes(:danger_outline),
                data: {confirm: "WARNING: Marking a supervisor inactive will make them unable to login. Are you sure you want to do this?"} do %>
            <i class="bi bi-slash-circle" aria-hidden="true"></i> Deactivate Supervisor
          <% end %>
        <% end %>
      <% else %>
        <% if policy(user).activate? %>
          <%= link_to activate_supervisor_path(user), method: :patch, class: button_classes(:success) do %>
            <i class="bi bi-check-circle" aria-hidden="true"></i> Activate supervisor
          <% end %>
        <% end %>
      <% end %>

      <% if current_user.casa_admin? && user.invitation_accepted_at.nil? %>
        <%= link_to resend_invitation_supervisor_path(user), method: :patch, class: button_classes(:secondary) do %>
          <i class="bi bi-send" aria-hidden="true"></i> Resend Invitation
        <% end %>
        <%= link_to change_to_admin_supervisor_path(user), method: :patch, class: button_classes(:secondary) do %>
          <i class="bi bi-person-up" aria-hidden="true"></i> Change to Admin
        <% end %>
      <% end %>
    </div>
  </div>
</section>
