<%# other_duties new/edit form (casa_app). Rendered by new + edit (thin wrappers) so it carries
    the page shell. The Hour(s)/Minute(s) duration inputs are the Tailwind twin (like learning
    hours); the controller's convert_duration_minutes combines them into duration_minutes. Notes
    stays `required` with the default #other_duty_notes id (a :js spec asserts the HTML5
    validation message). Spec-locked strings kept verbatim ("New duty" / "Editing duty",
    "Occurred on", "Duty duration", "Enter notes", "Submit") — queued for the sentence-case sweep. %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% occurred_at = other_duty.occurred_at || Time.zone.now %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <div>
      <%= link_to other_duties_path, class: "inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-slate-700" do %>
        <i class="bi bi-chevron-left text-xs" aria-hidden="true"></i> Back to other duties
      <% end %>
    </div>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= title %></h1>

    <%= form_with model: other_duty do |form| %>
      <%= render "shared/form_errors", resource: other_duty %>

      <section class="<%= card %> mt-4 space-y-5">
        <div>
          <%= form.label :occurred_at, "Occurred on", class: label_class %>
          <%= form.date_field :occurred_at, value: occurred_at.to_date, class: input_class %>
        </div>

        <fieldset class="m-0 border-0 p-0">
          <legend class="<%= label_class %>">Duty duration</legend>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label :duration_hours, "Hour(s)", class: label_class %>
              <%= form.number_field :duration_hours, min: 0, value: duration_hours(other_duty), required: true, class: input_class %>
            </div>
            <div>
              <%= form.label :duration_minutes, "Minute(s)", class: label_class %>
              <%= form.number_field :duration_minutes, min: 0, value: duration_minutes(other_duty), required: true, class: input_class %>
            </div>
          </div>
        </fieldset>

        <div>
          <%= form.label :notes, "Enter notes *", class: label_class %>
          <%= form.text_area :notes, rows: 5, placeholder: "Enter notes here", required: true, class: input_class %>
        </div>

        <div class="actions">
          <%= form.button type: "submit", class: button_classes(:primary) do %>
            <i class="bi bi-check-lg" aria-hidden="true"></i> Submit
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
