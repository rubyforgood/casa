<% content_for :page_title, "Other duties" %>
<%# other_duties#index on casa_app. Grouped by volunteer (admins/supervisors see many; a volunteer
    sees only their own). Bespoke Tailwind tables + a mobile card twin. "Other duties" heading +
    the "New duty" link are spec-locked. %>
<% th = "px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top" %>
<% td = "px-4 py-3 align-top text-sm text-slate-700" %>
<% ghost = "inline-flex items-center gap-1.5 rounded-lg px-2 py-1 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" %>
<% groups = @volunteer_duties.select { |g| g[:other_duties].any? } %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Other duties</h1>
    <% if current_user.volunteer? %>
      <%= link_to new_other_duty_path, class: button_classes(:primary) do %><i class="bi bi-plus-lg" aria-hidden="true"></i> New duty<% end %>
    <% end %>
  </div>

  <% if groups.empty? %>
    <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
      <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-clipboard-check text-xl" aria-hidden="true"></i></div>
      <p class="mt-3 text-sm text-slate-500">There are no duties to display yet.</p>
    </div>
  <% else %>
    <div class="space-y-8">
      <% groups.each do |group| %>
        <% duties = group[:other_duties].decorate %>
        <section>
          <% unless current_user.id == group[:volunteer].id %>
            <h2 class="mb-3 text-lg font-semibold text-slate-900"><%= link_to formatted_name(group[:volunteer].display_name), volunteer_path(group[:volunteer]), class: "hover:text-brand-700 hover:underline" %></h2>
          <% end %>

          <%# Desktop table (md+) %>
          <div class="hidden overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-sm md:block">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-100">
                    <th class="<%= th %>">Occurred</th>
                    <th class="<%= th %>">Created</th>
                    <th class="<%= th %>">Duration</th>
                    <th class="<%= th %>">Notes</th>
                    <% if current_user.volunteer? %><th class="<%= th %>"><span class="sr-only">Actions</span></th><% end %>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                  <% duties.each do |duty| %>
                    <tr class="hover:bg-slate-50/70">
                      <td class="<%= td %> whitespace-nowrap"><%= I18n.l(duty.occurred_at, format: :full, default: nil) %></td>
                      <td class="<%= td %> whitespace-nowrap"><%= I18n.l(duty.created_at, format: :full, default: nil) %></td>
                      <td class="<%= td %> whitespace-nowrap"><%= duty.duration_in_minutes %></td>
                      <td class="<%= td %> max-w-md"><%= duty.truncate_notes %></td>
                      <% if current_user.volunteer? %>
                        <td class="px-4 py-3 text-right whitespace-nowrap align-top"><%= link_to edit_other_duty_path(duty), class: ghost do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %></td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <%# Mobile cards (below md) %>
          <ul class="space-y-3 md:hidden">
            <% duties.each do |duty| %>
              <li class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex items-start justify-between gap-3">
                  <p class="text-sm font-semibold text-slate-900"><%= I18n.l(duty.occurred_at, format: :full, default: nil) %></p>
                  <% if current_user.volunteer? %>
                    <%= link_to edit_other_duty_path(duty), "aria-label": "Edit duty", class: "#{ghost} -mr-1 -mt-1 flex-none" do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
                  <% end %>
                </div>
                <dl class="mt-2 space-y-2">
                  <div class="flex justify-between gap-4"><dt class="text-xs text-slate-500">Duration</dt><dd class="text-sm text-slate-700"><%= duty.duration_in_minutes %></dd></div>
                  <div class="flex justify-between gap-4"><dt class="text-xs text-slate-500">Created</dt><dd class="text-sm text-slate-700"><%= I18n.l(duty.created_at, format: :full, default: nil) %></dd></div>
                  <div><dt class="text-xs text-slate-500">Notes</dt><dd class="mt-0.5 text-sm text-slate-700"><%= duty.truncate_notes %></dd></div>
                </dl>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </div>
  <% end %>
</div>
