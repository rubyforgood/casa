<% content_for :page_title, "Create a new CASA Organization" %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Create a new CASA Organization</h1>
    <div class="<%= card %>">
      <%= form_with model: selected_organization, url: all_casa_admins_casa_orgs_path, method: :post, local: true, class: "space-y-5" do |form| %>
        <%= render "shared/form_errors", resource: selected_organization %>
        <div>
          <%= form.label :name, "Name", class: label_class %>
          <%= form.text_field :name, class: input_class, required: true %>
        </div>
        <div>
          <%= form.label :display_name, "Display name", class: label_class %>
          <%= form.text_field :display_name, class: input_class %>
        </div>
        <div>
          <%= form.label :address, "Address", class: label_class %>
          <%= form.text_field :address, class: input_class %>
        </div>
        <div>
          <%= button_tag type: "submit", id: "submit", class: button_classes(:primary) do %>
            <i class="bi bi-check-lg" aria-hidden="true"></i> Create CASA Organization
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
