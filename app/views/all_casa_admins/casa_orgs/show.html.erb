<% content_for :page_title, selected_organization.name %>
<% card = "rounded-2xl border border-slate-200 bg-white shadow-sm" %>
<% th = "px-3 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500" %>
<% td = "px-3 py-3 text-sm text-slate-700 align-top" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= selected_organization.name %></h1>

    <div class="<%= card %>">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 p-5 sm:p-6">
        <h2 class="text-lg font-semibold text-slate-900">Administrators</h2>
        <div class="flex flex-wrap gap-2">
          <%= link_to new_all_casa_admins_casa_org_casa_admin_path(selected_organization), class: button_classes(:primary) do %>
            <i class="bi bi-plus-lg" aria-hidden="true"></i> New CASA Admin
          <% end %>
          <%= link_to "Return to Organizations", authenticated_all_casa_admin_root_path, class: button_classes(:secondary) %>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="<%= th %>">Name</th>
              <th scope="col" class="<%= th %>">Email</th>
              <th scope="col" class="<%= th %>">Created at</th>
              <th scope="col" class="<%= th %> text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% selected_organization.casa_admins.each do |admin| %>
              <tr class="admin-<%= admin.id %>">
                <td class="<%= td %> font-medium text-slate-800"><%= admin.display_name %></td>
                <td class="<%= td %>"><%= admin.email %></td>
                <td class="<%= td %> whitespace-nowrap"><%= I18n.l(admin.created_at, format: :full, default: nil) %></td>
                <td class="<%= td %> text-right"><%= link_to "Edit", edit_all_casa_admins_casa_org_casa_admin_path(selected_organization, admin), class: "font-medium text-brand-600 hover:text-brand-700" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="<%= card %> p-5 sm:p-6">
      <h3 class="mb-3 text-lg font-semibold text-slate-900">Details</h3>
      <ul class="divide-y divide-slate-100 text-sm text-slate-700">
        <% @casa_org_metrics.each do |item_description, item_value| %>
          <li class="py-2"><span class="font-medium text-slate-800"><%= item_description %>:</span> <%= item_value %></li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
