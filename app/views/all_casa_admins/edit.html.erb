<% content_for :page_title, "Edit profile" %>
<%# The change-password section uses the disclosure Stimulus controller (Tailwind hidden toggle),
    like the regular user edit-profile page — Bootstrap collapse CSS is not loaded on this shell.
    The panel keeps id="collapseOne" (specs reference it). error_messages stays for #error_explanation. %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Edit profile</h1>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" data-controller="disclosure">
      <%= form_with(model: @user, scope: :all_casa_admin, url: all_casa_admins_path, method: :patch, class: "space-y-5") do |form| %>
        <%= render "shared/error_messages", resource: @user %>
        <div>
          <%= form.label :email, "Email", class: label_class %>
          <%= form.email_field :email, class: input_class %>
        </div>
        <div class="flex flex-wrap gap-2">
          <%= form.button "Update profile", type: "submit", class: button_classes(:primary) %>
          <button type="button" data-action="disclosure#toggle" data-disclosure-target="trigger" aria-expanded="false" aria-controls="collapseOne" class="<%= button_classes(:secondary) %>">Change password</button>
        </div>
      <% end %>

      <div id="collapseOne" data-disclosure-target="panel" class="hidden mt-5 border-t border-slate-100 pt-5">
        <%= form_with(model: @user, scope: :all_casa_admin, url: {action: "update_password"}, method: :patch, class: "space-y-5") do |f| %>
          <div>
            <%= f.label :password, "Password", class: label_class %>
            <%= f.password_field :password, autocomplete: "off", minlength: 6, class: input_class %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Password confirmation", class: label_class %>
            <%= f.password_field :password_confirmation, minlength: 6, class: input_class %>
          </div>
          <div>
            <%= f.submit "Update password", class: button_classes(:danger) %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
