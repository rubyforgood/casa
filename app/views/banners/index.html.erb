<% content_for :page_title, "Banners" %>
<%# banners#index on the casa_app shell. The active banner itself renders at the top of every
    page via layouts/_casa_banner; this admin list manages them. Only one banner can be active at
    a time. The Active? cell keeps its .min-width class (a system spec asserts td.min-width Yes/No). %>
<% card = "rounded-2xl border border-slate-200 bg-white shadow-sm" %>
<% th = "px-3 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500" %>
<% td = "px-3 py-3 text-sm text-slate-700 align-top" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
      <div class="max-w-2xl">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Banners</h1>
        <p class="mt-1 text-sm text-slate-500">Banners display at the top of the page to call out a message to volunteers — for example a link to a survey. You can create multiple banners, but only one can be active at a time.</p>
      </div>
      <%= link_to new_banner_path, class: button_classes(:primary) do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i> New Banner
      <% end %>
    </div>

    <% if @banners.any? %>
      <div class="<%= card %> overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200" id="banners">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="<%= th %>">Name</th>
                <th scope="col" class="<%= th %>">Active?</th>
                <th scope="col" class="<%= th %>">Expiration</th>
                <th scope="col" class="<%= th %>">Last updated by</th>
                <th scope="col" class="<%= th %>">Updated at</th>
                <th scope="col" class="<%= th %> text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @banners.each do |banner| %>
                <tr>
                  <td class="<%= td %> font-medium text-slate-800"><%= banner.name %></td>
                  <td class="<%= td %> min-width"><%= banner.active? ? "Yes" : "No" %></td>
                  <td class="<%= td %> whitespace-nowrap"><%= banner_expiration_time_in_words(banner) %></td>
                  <td class="<%= td %> font-medium text-slate-800"><%= formatted_name(banner.user.display_name) %></td>
                  <td class="<%= td %> whitespace-nowrap text-slate-500"><%= time_ago_in_words(banner.updated_at) %> ago</td>
                  <td class="<%= td %> text-right">
                    <div class="inline-flex items-center gap-2">
                      <%= link_to edit_banner_path(banner), class: button_classes(:secondary) do %>
                        <i class="bi bi-pencil" aria-hidden="true"></i> Edit
                      <% end %>
                      <%= render "shared/confirm_button", url: banner_path(banner), method: :delete, title: "Delete banner?", message: "This banner will be permanently deleted.", confirm_label: "Delete", trigger_icon: "bi bi-trash", trigger_label: "Delete", trigger_class: button_classes(:danger_outline) %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="<%= card %> px-6 py-16 text-center">
        <div class="mx-auto mb-4 grid h-12 w-12 place-items-center rounded-full bg-slate-100 text-slate-400"><i class="bi bi-megaphone text-xl" aria-hidden="true"></i></div>
        <h2 class="text-base font-semibold text-slate-900">No banners yet</h2>
        <p class="mt-1 text-sm text-slate-500">Create a banner to display an announcement to volunteers.</p>
      </div>
    <% end %>
  </div>
</div>
