<%# A single learning-hours entry (casa_app). Only the owner reaches this (policy show? =
    owner), so Edit/Delete always show. Delete keeps the UJS confirm. %>
<% content_for :page_title, @learning_hour.name %>
<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl space-y-6">
    <div>
      <%= link_to learning_hours_path, class: "inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-slate-700" do %>
        <i class="bi bi-chevron-left text-xs" aria-hidden="true"></i> Back to learning hours
      <% end %>
    </div>

    <div class="flex flex-wrap items-start justify-between gap-3">
      <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= @learning_hour.name %></h1>
      <div class="flex items-center gap-2">
        <%= link_to edit_learning_hour_path(@learning_hour), class: button_classes(:secondary) do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
        <%= button_to learning_hour_path(@learning_hour), method: :delete, form_class: "contents", class: button_classes(:danger_outline), data: {confirm: "Are you sure to delete this learning record?"} do %><i class="bi bi-trash" aria-hidden="true"></i> Delete<% end %>
      </div>
    </div>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
      <dl class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-slate-500">Title</dt>
          <dd class="mt-0.5 text-sm text-slate-800"><%= @learning_hour.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Learning type</dt>
          <dd class="mt-0.5 text-sm text-slate-800"><%= @learning_hour.learning_hour_type&.name %></dd>
        </div>
        <% if current_user.casa_org.learning_topic_active %>
          <div>
            <dt class="text-sm font-medium text-slate-500">Learning topic</dt>
            <dd class="mt-0.5 text-sm text-slate-800"><%= @learning_hour.learning_hour_topic&.name %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-sm font-medium text-slate-500">Date</dt>
          <dd class="mt-0.5 text-sm text-slate-800"><%= I18n.l(@learning_hour.occurred_at, format: :full) %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Time spent</dt>
          <dd class="mt-0.5 text-sm text-slate-800"><% if @learning_hour.duration_hours > 0 %><%= @learning_hour.duration_hours %> hr <% end %><%= @learning_hour.duration_minutes %> min</dd>
        </div>
      </dl>
    </section>
  </div>
</div>
