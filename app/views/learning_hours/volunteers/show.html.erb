<%# A volunteer's learning hours, viewed by a supervisor/admin (casa_app). Reuses the shared
    entries table. The possessive heading is spec-locked. %>
<% content_for :page_title, "Learning hours" %>
<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6">
    <%= link_to learning_hours_path, class: "inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-slate-700" do %>
      <i class="bi bi-chevron-left text-xs" aria-hidden="true"></i> Back to learning hours
    <% end %>
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900"><%= formatted_name(@volunteer.display_name) %>'s learning hours</h1>
  </div>

  <%= render "learning_hours/learning_hours_table", learning_hours: @learning_hours %>
</div>
