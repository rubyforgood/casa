<% content_for :page_title, "CASA admins" %>
<%# casa_admins#index on casa_app. Bespoke Tailwind roster (email + Edit); no DataTable. The
    `#admins` spec hook lives on the wrapper div. "Deactivated" tag + the "New admin" CTA are
    spec-locked. %>
<% th = "px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top" %>
<% td = "px-4 py-3 text-sm text-slate-700 align-top" %>
<% pill = "inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium" %>
<% ghost = "inline-flex items-center gap-1.5 rounded-lg px-2 py-1 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">CASA admins</h1>
    <%= link_to new_casa_admin_path, class: button_classes(:primary) do %><i class="bi bi-plus-lg" aria-hidden="true"></i> New admin<% end %>
  </div>

  <div id="admins" class="overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100">
            <th class="<%= th %>">Admin</th>
            <th class="<%= th %>"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% if @admins.any? %>
            <% @admins.each do |admin| %>
              <tr id="admin-<%= admin.id %>" class="hover:bg-slate-50/70">
                <td class="<%= td %>">
                  <div class="flex flex-wrap items-center gap-2">
                    <%= link_to admin.email, edit_casa_admin_path(admin), class: "font-medium text-slate-800 hover:text-brand-700 hover:underline" %>
                    <% unless admin.active? %>
                      <span class="<%= pill %> bg-slate-100 text-slate-600"><i class="bi bi-dash-circle" aria-hidden="true"></i> Deactivated</span>
                    <% end %>
                  </div>
                  <% if admin.display_name.present? %>
                    <p class="mt-0.5 text-xs text-slate-500"><%= formatted_name(admin.display_name) %></p>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <%= link_to edit_casa_admin_path(admin), "aria-label": "Edit #{admin.email}", class: ghost do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="2" class="px-4 py-14 text-center">
                <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-person-gear text-xl" aria-hidden="true"></i></div>
                <p class="mt-3 text-sm font-semibold text-slate-900">No admins found</p>
                <p class="mt-1 text-sm text-slate-500">New CASA admins will appear here.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
