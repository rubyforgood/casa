<%# casa_app-styled error summary for the CASA-admin forms. Reproduces the legacy
    shared/_error_messages contract the specs lock — the `#error_explanation` id and the
    "N errors prohibited this Casa admin from being saved:" header — but on the Tailwind
    rose card instead of Bootstrap alert markup (design system doesn't load Bootstrap CSS). %>
<% if resource.errors.any? %>
  <div id="error_explanation" role="alert" class="rounded-xl border border-rose-200 bg-rose-50 p-4">
    <h2 class="flex items-start gap-2 text-sm font-semibold text-rose-800">
      <i class="bi bi-exclamation-triangle mt-0.5" aria-hidden="true"></i>
      <span><%= pluralize(resource.errors.count, "error") %> prohibited this <%= resource.model_name.human %> from being saved:</span>
    </h2>
    <ul class="mt-2 list-disc space-y-1 pl-8 text-sm text-rose-700">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
