<%# Hearing type new/edit (casa_app): name + Active?, and (once persisted) a checklist-items
    table with New/Edit and a button_to Delete (a non-JS destroy spec drives "Delete", so no
    Dialog confirm — turbo_confirm only, which rack_test ignores). %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% check_class = "h-4 w-4 shrink-0 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= title %></h1>
    <div class="<%= card %>">
      <%= form_with model: hearing_type, local: true, class: "space-y-5" do |form| %>
        <%= render "shared/form_errors", resource: hearing_type %>
        <div>
          <%= form.label :name, "Name", class: label_class %>
          <%= form.text_field :name, required: true, class: input_class %>
        </div>
        <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= form.check_box :active, class: check_class %>
          <span>Active?</span>
        </label>
        <div>
          <%= button_tag type: "submit", class: button_classes(:primary) do %>
            <i class="bi bi-check-lg" aria-hidden="true"></i> Submit
          <% end %>
        </div>
      <% end %>
    </div>

    <% if hearing_type.persisted? %>
      <div class="<%= card %>">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-base font-semibold text-slate-900">Checklist</h2>
          <%= link_to new_hearing_type_checklist_item_path(hearing_type), class: button_classes(:secondary) do %>
            <i class="bi bi-plus-lg" aria-hidden="true"></i> New list item
          <% end %>
        </div>
        <div class="mt-4 hidden overflow-x-auto md:block">
          <table id="checklist_items" class="min-w-full divide-y divide-slate-200">
            <thead>
              <tr>
                <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Description</th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Category</th>
                <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Mandatory</th>
                <th scope="col" class="px-4 py-3 text-right text-xs font-semibold text-slate-600 align-top">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% hearing_type.checklist_items.each do |checklist_item| %>
                <tr id="checklist_item-<%= checklist_item.id %>">
                  <td class="px-4 py-3 text-sm text-slate-700 align-top"><%= checklist_item.description %></td>
                  <td class="px-4 py-3 text-sm text-slate-500 align-top"><%= checklist_item.category %></td>
                  <td class="px-4 py-3 text-sm text-slate-700 align-top"><%= checklist_item.mandatory ? "Yes" : "Optional" %></td>
                  <td class="px-4 py-3 text-right align-top text-sm">
                    <div class="flex items-center justify-end gap-3">
                      <%= link_to "Edit", edit_hearing_type_checklist_item_path(hearing_type, checklist_item), class: "font-medium text-brand-600 hover:text-brand-700" %>
                      <%= button_to "Delete", hearing_type_checklist_item_path(hearing_type, checklist_item), method: :delete, form_class: "inline", data: {turbo_confirm: "Are you sure that you want to delete this checklist item?"}, class: "font-medium text-rose-600 hover:text-rose-700" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="mt-4 space-y-3 md:hidden">
          <% hearing_type.checklist_items.each do |checklist_item| %>
            <div class="rounded-xl border border-slate-200 p-4">
              <p class="break-words font-medium text-slate-800"><%= checklist_item.description %></p>
              <dl class="mt-2 space-y-1 text-sm">
                <div class="flex justify-between gap-3">
                  <dt class="text-slate-500">Category</dt>
                  <dd class="text-right text-slate-500"><%= checklist_item.category %></dd>
                </div>
                <div class="flex justify-between gap-3">
                  <dt class="text-slate-500">Mandatory</dt>
                  <dd class="text-right text-slate-700"><%= checklist_item.mandatory ? "Yes" : "Optional" %></dd>
                </div>
              </dl>
              <div class="mt-3 flex items-center gap-4 border-t border-slate-100 pt-3 text-sm">
                <%= link_to "Edit", edit_hearing_type_checklist_item_path(hearing_type, checklist_item), class: "font-medium text-brand-600 hover:text-brand-700" %>
                <%= button_to "Delete", hearing_type_checklist_item_path(hearing_type, checklist_item), method: :delete, form_class: "inline", data: {turbo_confirm: "Are you sure that you want to delete this checklist item?"}, class: "font-medium text-rose-600 hover:text-rose-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
