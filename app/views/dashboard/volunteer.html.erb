<%#
  Volunteer landing dashboard (casadesign). Rendered by DashboardController#show inside
  the casa_app (Tailwind) layout. Data comes from VolunteerDashboard.
%>
<% content_for :page_title, "Dashboard" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Dashboard</h1>
      <p class="mt-1 text-sm text-slate-500"><%= @dashboard.rows.any? ? "Stay on top of your cases and contacts." : "Your cases will appear here." %></p>
    </div>
    <% if @dashboard.rows.any? %>
      <%= link_to new_case_contact_path, class: "inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2" do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i> Log a contact
      <% end %>
    <% end %>
  </div>

  <% if @dashboard.cases.empty? %>
    <div class="mx-auto max-w-lg py-16 text-center">
      <div class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-brand-50 text-brand-600"><i class="bi bi-folder2-open text-3xl" aria-hidden="true"></i></div>
      <h2 class="mt-5 text-xl font-bold tracking-tight text-slate-900">No cases assigned to you yet</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-slate-500">When a supervisor assigns you to a case, it'll show up here so you can log contacts and track your work.</p>
    </div>
  <% else %>
    <% stats = @dashboard.stats %>
    <% needs = stats[:needs_contact] %>

    <div class="grid grid-cols-2 gap-4 lg:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-brand-50 text-brand-600"><i class="bi bi-folder2" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= stats[:cases] %></div>
        <div class="text-sm text-slate-500">Active cases</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm <%= "ring-1 ring-rose-100" if needs.positive? %>">
        <span class="grid h-9 w-9 place-items-center rounded-xl <%= needs.positive? ? "bg-rose-50 text-rose-600" : "bg-emerald-50 text-emerald-600" %>"><i class="bi <%= needs.positive? ? "bi-exclamation-triangle" : "bi-check2-circle" %>" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight <%= needs.positive? ? "text-rose-600" : "text-slate-900" %>"><%= needs %></div>
        <div class="text-sm text-slate-500">Need a contact</div>
        <div class="mt-1 text-xs text-slate-500">Not contacted in <%= Volunteer::CONTACT_MADE_IN_DAYS_NUM %>+ days</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-emerald-50 text-emerald-600"><i class="bi bi-clock-history" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= stats[:hours_label] %></div>
        <div class="text-sm text-slate-500">Hours logged (30d)</div>
      </div>
    </div>

    <% if @dashboard.needs_attention.any? %>
      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm" aria-labelledby="attention-heading">
        <div class="mb-4 flex items-center justify-between">
          <h2 id="attention-heading" class="text-base font-semibold text-slate-900">Needs your attention</h2>
          <span class="text-sm text-slate-500"><%= pluralize(@dashboard.needs_attention.size, "case") %></span>
        </div>
        <ul class="space-y-2.5">
          <% @dashboard.needs_attention.each do |row| %>
            <li class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-rose-100 bg-rose-50/40 px-4 py-3">
              <div class="flex items-center gap-3">
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-rose-100 text-rose-600"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></span>
                <div>
                  <div class="font-semibold text-slate-800"><%= link_to row.casa_case.case_number, casa_case_path(row.casa_case), class: record_link_class %></div>
                  <div class="text-xs text-slate-500"><%= row.last_contact_label %></div>
                </div>
              </div>
              <%= link_to new_case_contact_path, class: "inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Log a contact
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <section class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white pb-2 shadow-sm" aria-labelledby="cases-heading">
      <div class="border-b border-slate-100 p-4"><h2 id="cases-heading" class="text-base font-semibold text-slate-900">Your cases</h2></div>
      <div class="hidden overflow-x-auto md:block">
        <table class="w-full text-sm">
          <caption class="sr-only">Your active cases with contact-follow-up status and most recent contact.</caption>
          <thead class="text-left text-xs font-semibold text-slate-500">
            <tr class="border-b border-slate-100">
              <th scope="col" class="px-4 py-3">Case</th>
              <th scope="col" class="px-4 py-3">Contact status</th>
              <th scope="col" class="px-4 py-3">Last contact</th>
              <th scope="col" class="px-4 py-3"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% @dashboard.rows.each do |row| %>
              <tr class="hover:bg-slate-50/70">
                <td class="px-4 py-3 align-top"><%= link_to row.casa_case.case_number, casa_case_path(row.casa_case), class: "font-medium #{record_link_class}" %></td>
                <td class="px-4 py-3 align-top">
                  <% if row.needs_contact? %>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-rose-50 px-2.5 py-1 text-xs font-medium text-rose-700"><i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i> Needs a contact</span>
                  <% else %>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> On track</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 align-top text-slate-600"><%= row.last_contact_label %></td>
                <td class="px-4 py-3 align-top text-right"><%= link_to "Log contact", new_case_contact_path, class: "text-sm font-medium text-brand-600 hover:text-brand-700 focus-visible:outline-none focus-visible:underline" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="divide-y divide-slate-100 md:hidden">
        <% @dashboard.rows.each do |row| %>
          <div class="p-4">
            <div class="flex items-center justify-between gap-3">
              <%= link_to row.casa_case.case_number, casa_case_path(row.casa_case), class: "font-medium #{record_link_class}" %>
              <% if row.needs_contact? %>
                <span class="inline-flex flex-none items-center gap-1.5 rounded-full bg-rose-50 px-2.5 py-1 text-xs font-medium text-rose-700"><i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i> Needs a contact</span>
              <% else %>
                <span class="inline-flex flex-none items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> On track</span>
              <% end %>
            </div>
            <div class="mt-2 flex items-center justify-between gap-3">
              <span class="text-xs text-slate-500"><%= row.last_contact_label %></span>
              <%= link_to "Log contact", new_case_contact_path, class: "text-sm font-medium text-brand-600 hover:text-brand-700 focus-visible:outline-none focus-visible:underline" %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
