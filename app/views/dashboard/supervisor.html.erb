<%#
  Supervisor landing dashboard (casadesign). Rendered by DashboardController#show
  inside the casa_app (Tailwind) layout. Data comes from SupervisorDashboard.
%>
<% content_for :page_title, "Dashboard" %>
<% avatar_classes = {
  "sky" => "bg-sky-100 text-sky-700",
  "violet" => "bg-violet-100 text-violet-700",
  "emerald" => "bg-emerald-100 text-emerald-700",
  "amber" => "bg-amber-100 text-amber-700",
  "rose" => "bg-rose-100 text-rose-700",
  "teal" => "bg-teal-100 text-teal-700",
  "indigo" => "bg-indigo-100 text-indigo-700"
} %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Dashboard</h1>
      <p class="mt-1 text-sm text-slate-500">
        <%= current_organization.name %> —
        <%= @dashboard.rows.any? ? "here's where your volunteers stand today." : "let's get your volunteers set up." %>
      </p>
    </div>
    <% if @dashboard.rows.any? %>
      <%= link_to volunteers_path, class: "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
        Manage all volunteers <i class="bi bi-arrow-right" aria-hidden="true"></i>
      <% end %>
    <% end %>
  </div>

  <% if @dashboard.volunteers.empty? %>
    <div class="mx-auto max-w-lg py-16 text-center">
      <div class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-brand-50 text-brand-600"><i class="bi bi-people text-3xl" aria-hidden="true"></i></div>
      <h2 class="mt-5 text-xl font-bold tracking-tight text-slate-900">No volunteers assigned to you yet</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-slate-500">Once volunteers are assigned to you, this is where you'll track their case-contact activity, follow-ups, and hours — so you can see who needs support at a glance.</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <%= link_to new_volunteer_path, class: "inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2" do %>
          <i class="bi bi-plus-lg" aria-hidden="true"></i> Invite a volunteer
        <% end %>
        <%= link_to volunteers_path, class: "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
          <i class="bi bi-person-plus" aria-hidden="true"></i> Assign existing volunteers
        <% end %>
      </div>
    </div>
  <% else %>
    <% stats = @dashboard.stats %>
    <% follow = stats[:needs_followup] %>

    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-brand-50 text-brand-600"><i class="bi bi-people" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= stats[:active] %></div>
        <div class="text-sm text-slate-500">Volunteers you supervise</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm <%= "ring-1 ring-rose-100" if follow.positive? %>">
        <span class="grid h-9 w-9 place-items-center rounded-xl <%= follow.positive? ? "bg-rose-50 text-rose-600" : "bg-emerald-50 text-emerald-600" %>"><i class="bi <%= follow.positive? ? "bi-exclamation-triangle" : "bi-check2-circle" %>" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight <%= follow.positive? ? "text-rose-600" : "text-slate-900" %>"><%= follow %></div>
        <div class="text-sm text-slate-500">Need follow-up</div>
        <div class="mt-1 text-xs text-slate-500">A case not contacted in 14+ days</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-slate-100 text-slate-600"><i class="bi bi-dash-circle" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= stats[:no_cases] %></div>
        <div class="text-sm text-slate-500">No active cases</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-emerald-50 text-emerald-600"><i class="bi bi-clock-history" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= stats[:hours_label] %></div>
        <div class="text-sm text-slate-500">Hours logged (30d)</div>
      </div>
    </div>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm" aria-labelledby="attention-heading">
      <div class="mb-4 flex items-center justify-between">
        <h2 id="attention-heading" class="text-base font-semibold text-slate-900">Needs your attention</h2>
        <% if @dashboard.needs_attention.any? %><span class="text-sm text-slate-500"><%= pluralize(@dashboard.needs_attention.size, "volunteer") %></span><% end %>
      </div>
      <% if @dashboard.needs_attention.any? %>
        <ul class="space-y-2.5">
          <% @dashboard.needs_attention.each do |row| %>
            <li class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-rose-100 bg-rose-50/40 px-4 py-3">
              <div class="flex items-center gap-3">
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-rose-100 text-rose-600"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></span>
                <div>
                  <div class="font-semibold text-slate-800"><%= display_person(row.volunteer) %></div>
                  <div class="text-xs text-slate-500"><%= pluralize(row.cases_count, "active case") %> · last contact <%= row.last_contact_label.downcase %></div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to edit_volunteer_path(row.volunteer), class: "inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
                  <i class="bi bi-bell" aria-hidden="true"></i> Send reminder
                <% end %>
                <%= link_to "View", edit_volunteer_path(row.volunteer), "aria-label": "View #{display_person(row.volunteer)}", class: "rounded-lg px-2 py-1.5 text-sm font-medium text-brand-600 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="flex items-center gap-4 rounded-xl border border-emerald-100 bg-emerald-50/40 p-4">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-emerald-100 text-emerald-600"><i class="bi bi-check2-circle text-xl" aria-hidden="true"></i></span>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">You're all caught up</h3>
            <p class="mt-0.5 text-sm text-slate-600">Every volunteer has logged contact with their active cases in the last 14 days. Nice work.</p>
          </div>
        </div>
      <% end %>
    </section>

    <section class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm" aria-labelledby="roster-heading">
      <div class="border-b border-slate-100 p-4"><h2 id="roster-heading" class="text-base font-semibold text-slate-900">Your volunteers</h2></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <caption class="sr-only">Your assigned volunteers with case counts, contact-follow-up status, and recent activity.</caption>
          <thead class="text-left text-xs uppercase tracking-wide text-slate-500">
            <tr class="border-b border-slate-100">
              <th scope="col" class="px-4 py-3 font-semibold">Volunteer</th>
              <th scope="col" class="px-4 py-3 text-center font-semibold">Cases</th>
              <th scope="col" class="px-4 py-3 font-semibold">Contact status</th>
              <th scope="col" class="px-4 py-3 font-semibold">Activity (60d)</th>
              <th scope="col" class="px-4 py-3"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% @dashboard.rows.each do |row| %>
              <tr class="hover:bg-slate-50/70">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full text-xs font-semibold <%= avatar_classes[row.avatar_color] %>" aria-hidden="true"><%= avatar_initials(display_person(row.volunteer)) %></span>
                    <div>
                      <div class="font-medium text-slate-800"><%= display_person(row.volunteer) %></div>
                      <div class="text-xs text-slate-500"><%= row.volunteer.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-center text-slate-700"><%= row.cases_count %></td>
                <td class="px-4 py-3">
                  <% if row.status == :on_track %>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> On track</span>
                  <% elsif row.status == :follow_up %>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-rose-50 px-2.5 py-1 text-xs font-medium text-rose-700"><i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i> Needs follow-up</span>
                  <% else %>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600"><i class="bi bi-dash-circle" aria-hidden="true"></i> No active cases</span>
                  <% end %>
                  <div class="mt-1 text-xs text-slate-500"><%= row.last_contact_label %></div>
                </td>
                <td class="px-4 py-3 text-slate-600">
                  <% if row.cases_count.positive? %>
                    <%= pluralize(row.contacts_recent, "contact") %> · <%= row.hours_label %>
                  <% else %>
                    <span class="text-slate-400" aria-hidden="true">—</span><span class="sr-only">No recent activity</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right">
                  <%= link_to edit_volunteer_path(row.volunteer), "aria-label": "View #{display_person(row.volunteer)}", class: "inline-grid h-8 w-8 place-items-center rounded-lg text-slate-400 hover:bg-slate-100 hover:text-slate-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
