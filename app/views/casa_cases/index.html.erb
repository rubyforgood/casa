<% content_for :page_title, current_user.volunteer? ? "My cases" : "Cases" %>
<% btn_primary = "inline-flex items-center gap-2 rounded-lg bg-brand-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2" %>
<% btn_secondary = "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" %>
<% th = "px-4 py-3 text-left text-xs font-semibold text-slate-600" %>
<% td = "px-4 py-3 text-slate-700" %>
<% col_count = current_user.volunteer? ? 6 : 7 %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">
      <% if current_user.volunteer? %>My <%= "Case".pluralize(@pagy.count) %><% else %><%= "Case".pluralize(@pagy.count) %><% end %>
    </h1>
    <div class="flex flex-wrap items-center gap-2">
      <% if policy(:dashboard).see_volunteers_section? %>
        <%= link_to new_casa_case_path, class: btn_primary do %><i class="bi bi-plus-lg" aria-hidden="true"></i> New Case<% end %>
      <% end %>
      <% if policy(:application).admin_or_supervisor? %>
        <%= link_to case_groups_path, class: btn_secondary do %><i class="bi bi-collection" aria-hidden="true"></i> Case Groups<% end %>
        <%= link_to new_bulk_court_date_path, class: btn_secondary do %><i class="bi bi-calendar-plus" aria-hidden="true"></i> New Bulk Court Date<% end %>
      <% end %>
    </div>
  </div>

  <% if policy(CasaCase).can_see_filters? %>
    <%= render "filter" %>
  <% end %>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100">
            <th class="<%= th %>">Case Number</th>
            <th class="<%= th %>">Hearing Type</th>
            <th class="<%= th %>">Judge</th>
            <th class="<%= th %>">Status</th>
            <th class="<%= th %>">Transition Aged Youth</th>
            <% unless current_user.volunteer? %>
              <th class="<%= th %>">Assigned To</th>
            <% end %>
            <th class="<%= th %>"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% if @casa_cases.any? %>
            <% @casa_cases.each do |casa_case| %>
              <tr class="hover:bg-slate-50/70">
                <td class="<%= td %>"><%= link_to casa_case.case_number, casa_case, class: "font-medium text-brand-600 hover:text-brand-700" %></td>
                <td class="<%= td %>"><%= casa_case.hearing_type_name.presence || tag.span("—", class: "text-slate-400") %></td>
                <td class="<%= td %>"><%= casa_case.judge_name.presence || tag.span("—", class: "text-slate-400") %></td>
                <td class="<%= td %>"><%= casa_case.decorate.status %></td>
                <td class="<%= td %>">
                  <% if casa_case.in_transition_age? %>
                    <span class="inline-flex items-center rounded-full bg-violet-50 px-2 py-0.5 text-xs font-medium text-violet-700">Yes</span>
                  <% else %>
                    <span class="text-slate-400">No</span>
                  <% end %>
                </td>
                <% unless current_user.volunteer? %>
                  <td class="<%= td %>">
                    <% if casa_case.active? %>
                      <%= safe_join(casa_case.assigned_volunteers.map { |vol|
                        link_to(formatted_name(vol.display_name), edit_volunteer_path(vol), class: "text-brand-600 hover:text-brand-700") }, ", ") %>
                    <% else %>
                      Case was deactivated on: <%= I18n.l(casa_case.updated_at, format: :standard, default: nil) %>
                    <% end %>
                  </td>
                <% end %>
                <td class="px-4 py-3 text-right">
                  <%= link_to edit_casa_case_path(casa_case), "aria-label": "Edit #{casa_case.case_number}", class: "inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" do %>
                    <i class="bi bi-pencil" aria-hidden="true"></i>Edit
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="<%= col_count %>" class="px-4 py-14 text-center">
                <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-folder2-open text-xl" aria-hidden="true"></i></div>
                <p class="mt-3 text-sm font-semibold text-slate-900">No cases found</p>
                <p class="mt-1 text-sm text-slate-500"><%= policy(CasaCase).can_see_filters? ? "Try adjusting your filters." : "Cases assigned to you will appear here." %></p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @casa_cases.any? %>
      <%= render "shared/pagination", pagy: @pagy %>
    <% end %>
  </div>
</div>
