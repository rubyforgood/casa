<% content_for :page_title, "Case #{@casa_case.case_number}" %>
<% btn_primary = "inline-flex items-center gap-2 rounded-lg bg-brand-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2" %>
<% btn_secondary = "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% section_title = "text-base font-semibold text-slate-900" %>
<% fact_label = "text-sm font-medium text-slate-500" %>
<% fact_value = "text-sm text-slate-800" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl space-y-6">
    <%# Header %>
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="text-sm font-medium text-brand-600"><%= link_to "Cases", casa_cases_path, class: "hover:text-brand-700" %></p>
        <h1 class="mt-1 text-2xl font-bold tracking-tight text-slate-900">Case <%= @casa_case.case_number %></h1>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <% if @casa_case.active? %>
          <%= link_to new_case_contact_path(case_contact: {casa_case_id: @casa_case.id}), class: btn_primary do %>
            <i class="bi bi-plus-lg" aria-hidden="true"></i> New Case Contact
          <% end %>
          <%= link_to edit_casa_case_path(@casa_case), class: btn_secondary do %>
            <i class="bi bi-pencil" aria-hidden="true"></i> Edit Case Details
          <% end %>
        <% end %>
        <% if @casa_case.in_transition_age? %>
          <%= link_to casa_case_emancipation_path(@casa_case), class: btn_secondary do %>
            Emancipation
            <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-700"><%= @casa_case.decorate.emancipation_checklist_count %></span>
          <% end %>
        <% end %>
        <% if @casa_case.casa_org.show_fund_request %>
          <%= link_to "New Fund Request", new_casa_case_fund_request_path(@casa_case), class: btn_secondary %>
        <% end %>
        <%# Generate court report (Tailwind modal + court-report Stimulus controller) %>
        <div data-controller="modal court-report" class="inline">
          <button type="button" data-action="modal#open" class="<%= btn_secondary %>">
            <i class="bi bi-file-earmark-word" aria-hidden="true"></i> Generate Court Report
          </button>
          <dialog id="generate-court-report" data-modal-target="dialog" data-action="click->modal#backdropClose"
                  class="w-[calc(100vw-2rem)] max-w-md rounded-2xl p-0 shadow-xl backdrop:bg-slate-900/40">
            <%= form_with url: generate_case_court_reports_path, local: false, data: {court_report_target: "form"} do |form| %>
              <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
                <h2 class="text-base font-semibold text-slate-900">Download court report</h2>
                <button type="button" data-action="modal#close" aria-label="Close" class="grid h-8 w-8 place-items-center rounded-lg text-slate-400 hover:bg-slate-100 hover:text-slate-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
                  <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
              </div>
              <div class="space-y-4 px-5 py-4">
                <p class="text-sm text-slate-600">Choose a date range for <span class="font-medium text-slate-900"><%= @casa_case.case_number %></span>.</p>
                <div data-court-report-target="error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700" role="alert"></div>
                <%= form.hidden_field :case_number, value: @casa_case.case_number %>
                <%= form.hidden_field :time_zone, data: {court_report_target: "timeZone"} %>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                  <div>
                    <%= form.label :start_date, "Starting from", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
                    <%= form.date_field :start_date, value: (@casa_case.most_recent_past_court_date&.date || Date.current), required: true,
                          class: "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
                  </div>
                  <div>
                    <%= form.label :end_date, "Ending at", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
                    <%= form.date_field :end_date, value: Date.current, required: true,
                          class: "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
                  </div>
                </div>
              </div>
              <div class="flex items-center justify-end gap-2 border-t border-slate-100 px-5 py-4">
                <button type="button" data-action="modal#close" class="<%= btn_secondary %>">Cancel</button>
                <button type="submit" data-action="court-report#generate" data-court-report-target="submit" class="<%= btn_primary %>">
                  <i class="bi bi-arrow-repeat hidden animate-spin" data-court-report-target="spinner" aria-hidden="true"></i>
                  <i class="bi bi-download" aria-hidden="true"></i> Generate Report
                </button>
              </div>
            <% end %>
          </dialog>
        </div>
      </div>
    </div>

    <%# Inactive banner %>
    <% unless @casa_case.active? %>
      <div class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3">
        <p class="text-sm text-rose-800">Case was deactivated on <%= I18n.l(@casa_case.updated_at, format: :standard, default: nil) %>.</p>
        <% if Pundit.policy(current_user, @casa_case).update_case_status? %>
          <%= link_to "Reactivate CASA Case", reactivate_casa_case_path(@casa_case), method: :patch,
                class: "inline-flex items-center gap-2 rounded-lg bg-rose-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-rose-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2" %>
        <% end %>
      </div>
    <% end %>

    <%# Case details %>
    <section class="<%= card %>">
      <h2 class="<%= section_title %>">Case details</h2>
      <dl class="mt-4 grid grid-cols-1 gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
        <div>
          <dt class="inline font-medium text-slate-500">Transition Aged Youth:</dt>
          <dd class="inline text-slate-800"><%= @casa_case.in_transition_age? ? "Yes" : "No" %></dd>
        </div>
        <div>
          <dt class="inline font-medium text-slate-500">Youth's Date in Care:</dt>
          <dd class="inline text-slate-800">
            <%= @casa_case.decorate.date_in_care || tag.span("Not set", class: "text-slate-500") %>
            <% if @casa_case.decorate.duration_in_care %><span class="text-slate-500"><%= @casa_case.decorate.duration_in_care %></span><% end %>
          </dd>
        </div>
        <div>
          <dt class="inline font-medium text-slate-500">Next Court Date:</dt>
          <dd class="inline text-slate-800">
            <%= I18n.l(@casa_case.next_court_date&.date, format: :day_and_date, default: "None set") %>
            <% if (cal = @casa_case.decorate.calendar_next_court_date) %>
              <span class="ml-1 inline-block align-middle" data-controller="add-to-calendar"
                    data-add-to-calendar-title-value="Next Court Date for <%= @casa_case.case_number %>"
                    data-add-to-calendar-start-value="<%= cal[:start] %>"
                    data-add-to-calendar-end-value="<%= cal[:end] %>"
                    data-add-to-calendar-tooltip-value="Add Next Court Date to Calendar"></span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="inline font-medium text-slate-500">Court Report Status:</dt>
          <dd class="inline text-slate-800">
            <%= @casa_case.decorate.court_report_submission %>
            <% unless @casa_case.court_report_not_submitted? %>
              <% if @casa_case.court_report_submitted? && @casa_case.court_reports.attached? %>
                &middot; <%= link_to "Click to download", rails_blob_path(@casa_case.latest_court_report, disposition: "attachment"), class: "font-medium text-brand-600 hover:text-brand-700" %>
              <% end %>
              <span class="text-slate-500">&middot; Submitted <%= @casa_case.decorate.court_report_submitted_date %></span>
            <% end %>
          </dd>
        </div>
      </dl>

      <% if @casa_case.case_court_orders.exists? %>
        <div class="mt-6 border-t border-slate-100 pt-4">
          <h3 class="text-sm font-semibold text-slate-900">Court Orders</h3>
          <ul class="mt-2 space-y-1.5">
            <% @casa_case.case_court_orders.each do |court_order| %>
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <span aria-hidden="true"><%= court_order.implementation_status_symbol %></span>
                <span><%= court_order.text %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render "placements", casa_case: @casa_case %>
    </section>

    <%# Court dates %>
    <% court_dates = @casa_case.court_dates.includes(:hearing_type).ordered_ascending.load %>
    <section class="<%= card %>">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="<%= section_title %>">Court dates</h2>
        <%= link_to new_casa_case_court_date_path(@casa_case), class: btn_secondary do %>
          <i class="bi bi-calendar-plus" aria-hidden="true"></i> Add a court date
        <% end %>
      </div>
      <% if court_dates.empty? %>
        <p class="mt-3 text-sm text-slate-500">No Court Dates</p>
      <% else %>
        <ul class="mt-3 divide-y divide-slate-100">
          <% court_dates.each do |pcd| %>
            <li class="flex flex-wrap items-center justify-between gap-2 py-2.5">
              <div class="flex items-center gap-3">
                <%= link_to pcd.decorate.court_date_info, casa_case_court_date_path(@casa_case, pcd), class: "text-sm font-medium text-brand-600 hover:text-brand-700" %>
                <% if (report = pcd.latest_associated_report) %>
                  <%= link_to "Attached report", rails_blob_path(report, disposition: "attachment"), class: "text-xs text-slate-500 hover:text-slate-700" %>
                <% end %>
              </div>
              <span data-controller="add-to-calendar"
                    data-add-to-calendar-title-value="Court Date <%= @casa_case.case_number %>"
                    data-add-to-calendar-start-value="<%= pcd.date.strftime("%Y-%m-%d") %>"
                    data-add-to-calendar-end-value="<%= pcd.date.strftime("%Y-%m-%d") %>"
                    data-add-to-calendar-tooltip-value="Add court date to calendar"></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>

    <%# Assigned volunteers %>
    <section class="<%= card %>">
      <h2 class="<%= section_title %>">Assigned Volunteers:</h2>
      <% assigned = Pundit.policy_scope(current_user, @casa_case.assigned_volunteers) %>
      <% if assigned.any? %>
        <ul class="mt-3 space-y-3">
          <% assigned.each do |volunteer| %>
            <li class="flex flex-wrap items-center justify-between gap-3">
              <% if current_user.volunteer? %>
                <span class="text-sm font-medium text-slate-800"><%= formatted_name(volunteer.display_name) %></span>
              <% else %>
                <%= link_to formatted_name(volunteer.display_name), edit_volunteer_path(volunteer), class: "text-sm font-medium text-brand-600 hover:text-brand-700" %>
                <%= render "casa_cases/volunteer_reminder_form", volunteer: volunteer %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-3 text-sm text-slate-500">No volunteers assigned.</p>
      <% end %>
    </section>

    <%# Case contacts %>
    <section class="<%= card %>">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="<%= section_title %>">Case contacts</h2>
        <% if @casa_case.case_contacts.present? %>
          <%= link_to casa_case_path(@casa_case, format: :xlsx), class: btn_secondary do %>
            <i class="bi bi-download" aria-hidden="true"></i> Download All
          <% end %>
        <% end %>
      </div>
      <% contacts = if current_user.supervisor? || current_user.casa_admin?
           @casa_case.decorate.case_contacts_ordered_by_occurred_at
         else
           @casa_case.decorate.case_contacts_filtered_by_active_assignment_ordered_by_occurred_at
         end.includes(:creator, :followups, :contact_types, contact_topic_answers: [:contact_topic]).grab_all(current_user) %>
      <div id="case_contacts_list" class="mt-4 space-y-3">
        <% if contacts.any? %>
          <%= render partial: "casa_cases/case_contact_card", collection: contacts, as: :contact %>
        <% else %>
          <p class="text-sm text-slate-500">No case contacts logged yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</div>

<%# Thank-you dialog (auto-opens on the success redirect; also clears the saved draft) %>
<% if params[:success].present? %>
  <div data-controller="modal local-storage-reset"
       data-modal-open-on-connect-value="true"
       data-local-storage-reset-key-value="casa-contact-form">
    <dialog data-modal-target="dialog" data-action="click->modal#backdropClose"
            class="w-[calc(100vw-2rem)] max-w-md rounded-2xl p-0 shadow-xl backdrop:bg-slate-900/40">
      <div class="px-6 pt-6 text-center">
        <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-emerald-50 text-emerald-600"><i class="bi bi-check-lg text-xl" aria-hidden="true"></i></div>
        <h2 class="mt-3 text-base font-semibold text-slate-900">Case contact created</h2>
        <p class="mt-1 text-sm text-slate-600"><%= thank_you_message %></p>
        <% case when_do_we_have_court_dates(@casa_case)
           when "future" %>
          <p class="mt-3 text-sm text-slate-500">Please enter the previous court date if you know it so court reports can be generated with the correct case contacts.</p>
        <% when "past" %>
          <p class="mt-3 text-sm text-slate-500">Please enter the next court date if you know it so court reports can be generated with the correct case contacts.</p>
        <% when "none" %>
          <p class="mt-3 text-sm text-slate-500">Please enter any past or future court dates if you know them so court reports can be generated with the correct case contacts.</p>
        <% end %>
      </div>
      <div class="mt-5 flex justify-center border-t border-slate-100 px-6 py-4">
        <button type="button" data-action="modal#close" class="<%= btn_secondary %>">Close</button>
      </div>
    </dialog>
  </div>
<% end %>
