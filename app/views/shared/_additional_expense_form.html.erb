<%# Nested additional-expense row for the case-contact form (rendered only there). casa-nested-form
    clones this from the <template>, so keep .nested-form-wrapper, the wrapper target,
    data-new-record/child-index, and the hidden id/_destroy fields (the _destroy field carries the
    expenseDestroy target the case-contact-form controller flips). .expense-amount-input /
    .expense-describe-input drive the specs; .remove-expense-button + destroyAndRemove drive delete. %>
<%# Divider between rows (border-t py-4). Fields stack with visible labels in a left column; a
    compact trash delete sits at the top-right (flex items-start) so it takes no extra row. %>
<div class="nested-form-wrapper flex items-start gap-3 border-t border-slate-200 py-4"
  data-new-record="<%= form.object.new_record? %>"
  data-casa-nested-form-target="wrapper"
  data-child-index="<%= form.options[:child_index] %>">
  <div class="min-w-0 flex-1 space-y-4">
    <div>
      <%= form.label :other_expense_amount, "Other expense amount", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
      <div class="flex">
        <span class="inline-flex items-center rounded-l-lg border border-r-0 border-slate-300 bg-slate-100 px-3 text-sm text-slate-500">$</span>
        <%= form.number_field(:other_expense_amount,
          value: number_with_precision(form.object.other_expense_amount, precision: 2),
          placeholder: "0", min: "0", max: 1000, step: 0.01,
          class: "expense-amount-input block w-full rounded-r-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none"
        ) %>
      </div>
    </div>
    <div>
      <%= form.label :other_expenses_describe, class: "mb-1.5 block text-sm font-medium text-slate-700" do %>Other expense details <span class="text-rose-600" aria-hidden="true">*</span><% end %>
      <%= form.text_area(:other_expenses_describe,
        placeholder: "Enter other expense details",
        rows: 2,
        class: "expense-describe-input block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none",
        data: {action: "input->autosave#save"}
      ) %>
    </div>
  </div>
  <button type="button"
    class="remove-expense-button grid h-8 w-8 shrink-0 place-items-center rounded-lg text-slate-400 transition-colors hover:bg-rose-50 hover:text-rose-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500"
    aria-label="Delete expense" title="Delete expense"
    data-action="casa-nested-form#destroyAndRemove">
    <i class="bi bi-trash" aria-hidden="true"></i>
  </button>
  <%= form.hidden_field :id, value: form.object.id %>
  <%= form.hidden_field :_destroy, data: {case_contact_form_target: "expenseDestroy"} %>
</div>
