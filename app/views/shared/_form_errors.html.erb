<%# Tailwind form-error summary for casadesign pages. The legacy shared/_error_messages
    stays for Bootstrap pages. %>
<% if resource.errors.any? %>
  <div id="error_explanation" role="alert" class="flex items-center gap-3 rounded-xl border border-rose-200 bg-rose-50 p-4">
    <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-rose-100 text-rose-600">
      <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
    </span>
    <p class="text-sm text-rose-800"><span class="font-semibold">Unable to save:</span> <%= resource.errors.full_messages.to_sentence %></p>
  </div>
<% end %>
