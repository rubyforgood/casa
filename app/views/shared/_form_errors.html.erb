<%# Form-error summary for casadesign pages -- the shared design-system alert card (alert_classes,
    danger variant + leading icon), matching the flash banners. One sentence via to_sentence, no
    bulleted list. Keeps id="error_explanation" + the `alert` class (spec hooks). %>
<% if resource.errors.any? %>
  <div id="error_explanation" role="alert" class="alert <%= alert_classes(:danger) %>">
    <i class="bi <%= alert_icon(:danger) %> mt-0.5 shrink-0 text-base" aria-hidden="true"></i>
    <p><span class="font-semibold">Unable to save:</span> <%= resource.errors.full_messages.to_sentence %></p>
  </div>
<% end %>
