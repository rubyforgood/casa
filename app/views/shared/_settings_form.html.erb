<%# Shared casa_app CRUD form for the simple org-settings resources reached from casa_org/edit
    (judge, language, placement type, learning-hour type/topic): a name field, an optional
    Active? checkbox, an optional description, and Submit. Locals:
      model         the AR model (required; form_with infers the url + param key)
      title         the h1 (required)
      show_active   render the Active? checkbox (default false)
      description   optional intro text %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% check_class = "h-4 w-4 shrink-0 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= title %></h1>
    <div class="<%= card %>">
      <%= form_with model: model, local: true, class: "space-y-5" do |form| %>
        <%= render "shared/form_errors", resource: model %>
        <% if local_assigns[:description].present? %>
          <p class="text-sm text-slate-500"><%= description %></p>
        <% end %>
        <div>
          <%= form.label :name, "Name", class: label_class %>
          <%= form.text_field :name, required: true, class: input_class %>
        </div>
        <% if local_assigns[:show_active] %>
          <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
            <%= form.check_box :active, class: check_class %>
            <span>Active?</span>
          </label>
        <% end %>
        <div>
          <%= button_tag type: "submit", class: button_classes(:primary) do %>
            <i class="bi bi-check-lg" aria-hidden="true"></i> Submit
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
