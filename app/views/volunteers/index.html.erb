<% content_for :page_title, "Volunteers" %>
<%# volunteers#index on the casa_app shell. Bespoke Tailwind table (server-side filters +
    search + sortable headers + Pagy), reusing VolunteerDatatable's SQL; retires the jQuery
    DataTable. The column-visibility picker is intentionally dropped (see design.md — a
    responsive layout beats a picker). Bulk supervisor assignment (select-all + a native-dialog
    modal + disable-form) is preserved; its checkboxes live in the desktop table only (a desktop
    admin power tool), so the select-all targets stay unique. Spec hooks: #volunteers,
    #checkbox-toggle-all, #supervisor_volunteer_volunteer_ids_<id>, .supervisor-column,
    #supervisor_volunteer_supervisor_id. %>
<% th = "px-4 py-3 text-left text-xs font-semibold text-slate-600 whitespace-nowrap align-top" %>
<% td = "px-4 py-3 text-sm text-slate-700 align-top" %>
<% pill = "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium" %>
<% checkbox_class = "h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Volunteers</h1>
    <% if policy(current_organization.volunteers.new).new? %>
      <%= link_to new_volunteer_path, class: button_classes(:primary) do %><i class="bi bi-plus-lg" aria-hidden="true"></i> New volunteer<% end %>
    <% end %>
  </div>

  <%= render "filter" %>

  <% if @search.present? %>
    <p class="mb-4 text-sm text-slate-500">Showing <%= @pagy.count %> <%= "volunteer".pluralize(@pagy.count) %> matching &ldquo;<%= @search %>&rdquo;</p>
  <% end %>

  <%# hidden! (Tailwind v4 important) so the select-all controller can reliably hide the trigger:
      a plain `hidden` loses to button_classes' `inline-flex` in the cascade. %>
  <div data-controller="select-all modal" data-select-all-hidden-class="hidden!" data-select-all-button-label-value="Manage volunteer">
    <%# mb-4 on the button (not a reserved-height wrapper) so the space collapses while the
        button is hidden: the filter's own mb-4 then sets the filter->table gap, matching the
        cases index. The button pushes the table down only once a row is selected. %>
    <button type="button" class="<%= button_classes(:secondary) %> mb-4 hidden!" data-select-all-target="button" data-action="modal#open">
      <i class="bi bi-people" aria-hidden="true"></i> <span data-select-all-target="buttonLabel"></span>
    </button>

    <%= form_with url: bulk_assignment_supervisor_volunteers_path, method: :post, id: "form-bulk-assignment", data: {controller: "disable-form", "disable-form-unallowed-value": ["unselected"].to_json, "disable-form-disabled-class": "opacity-60", "disable-form-enabled-class": "shadow-sm"} do |form| %>

      <%# Desktop table (md+). #volunteers lives on the wrapper (not the <table>) so the legacy
          dashboard.js `$('table#volunteers').DataTable(...)` no longer matches and no jQuery
          DataTable initializes over the migrated table. %>
      <div id="volunteers" class="hidden overflow-hidden rounded-2xl border border-slate-200 bg-white pt-2 shadow-sm md:block">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-slate-100">
                <%# Bare, labeled select-all (industry standard for a bulk table: Gmail/GitHub/etc.).
                    aria-label + title give it a name without widening this narrow column. mt-0.5
                    drops the box onto the header text line. %>
                <th class="px-3 py-3 align-top">
                  <input type="checkbox" id="checkbox-toggle-all" aria-label="Select all" title="Select all" class="<%= checkbox_class %> mt-0.5" data-select-all-target="checkboxAll" data-action="select-all#toggleAll">
                </th>
                <%= sortable_header("Name", "display_name", sort: @sort, direction: @direction) %>
                <%= sortable_header("Email", "email", sort: @sort, direction: @direction) %>
                <%= sortable_header("Supervisor", "supervisor_name", sort: @sort, direction: @direction) %>
                <%= sortable_header("Status", "active", sort: @sort, direction: @direction) %>
                <%= sortable_header("Transition-aged youth", "has_transition_aged_youth_cases", sort: @sort, direction: @direction) %>
                <th class="<%= th %>">Case numbers</th>
                <%= sortable_header("Last attempted contact", "most_recent_attempt_occurred_at", sort: @sort, direction: @direction) %>
                <%= sortable_header("Contacts (60 days)", "contacts_made_in_past_days", sort: @sort, direction: @direction) %>
                <%= sortable_header("Hours (30 days)", "hours_spent_in_days", sort: @sort, direction: @direction) %>
                <th class="<%= th %>">Extra languages</th>
                <th class="<%= th %>"><span class="sr-only">Actions</span></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% if @volunteers.any? %>
                <% @volunteers.each do |volunteer| %>
                  <tr class="hover:bg-slate-50/70">
                    <td class="px-3 py-3 align-top"><input type="checkbox" name="supervisor_volunteer[volunteer_ids][]" id="supervisor_volunteer_volunteer_ids_<%= volunteer.id %>" value="<%= volunteer.id %>" aria-label="Select <%= formatted_name(volunteer.display_name) %>" class="<%= checkbox_class %> mt-0.5" data-select-all-target="checkbox" data-action="select-all#toggleSingle"></td>
                    <td class="<%= td %>"><%= link_to formatted_name(volunteer.display_name).presence || volunteer.email, edit_volunteer_path(volunteer), class: "font-medium #{name_link_class}" %></td>
                    <td class="<%= td %> text-slate-600"><%= volunteer.email %></td>
                    <td class="supervisor-column <%= td %>"><% if volunteer.supervisor_name.present? %><span class="font-medium text-slate-800"><%= formatted_name(volunteer.supervisor_name) %></span><% end %></td>
                    <td class="<%= td %>"><%= volunteer.active? ? "Active" : "Inactive" %></td>
                    <td class="<%= td %>">
                      <% if volunteer.has_transition_aged_youth_cases %>
                        <span class="<%= pill %> bg-violet-50 text-violet-700">Yes</span>
                      <% else %>
                        <span class="text-slate-500">No</span>
                      <% end %>
                    </td>
                    <td class="<%= td %>"><%= safe_join(volunteer.casa_cases.map { |cc| link_to cc.case_number, casa_case_path(cc), class: "text-brand-600 hover:text-brand-700 hover:underline" }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %></td>
                    <td class="<%= td %>">
                      <% if volunteer.most_recent_attempt_case_id %>
                        <%= link_to I18n.l(volunteer.most_recent_attempt_occurred_at, format: :full, default: "\u2014"), casa_case_path(volunteer.most_recent_attempt_case_id), class: "text-brand-600 hover:text-brand-700 hover:underline" %>
                      <% else %>
                        <span class="text-slate-500">None</span>
                      <% end %>
                    </td>
                    <td class="<%= td %>"><%= volunteer.contacts_made_in_past_days || 0 %></td>
                    <td class="<%= td %>"><%= volunteer.hours_spent_in_days(30).presence || tag.span("\u2014", class: "text-slate-500") %></td>
                    <td class="<%= td %>"><% langs = volunteer.languages.map(&:name) %><%= langs.any? ? langs.join(", ") : tag.span("\u2014", class: "text-slate-500") %></td>
                    <td class="px-3 py-3 text-right whitespace-nowrap align-top">
                      <div class="flex items-center justify-end gap-1">
                        <%= link_to edit_volunteer_path(volunteer), class: ghost_class, "aria-label": "Edit #{formatted_name(volunteer.display_name)}" do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
                        <% if policy(volunteer).impersonate? %>
                          <%= link_to impersonate_volunteer_path(volunteer), class: ghost_class, "aria-label": "Impersonate #{formatted_name(volunteer.display_name)}" do %><i class="bi bi-person-badge" aria-hidden="true"></i> Impersonate<% end %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="12" class="px-4 py-14 text-center">
                    <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-people text-xl" aria-hidden="true"></i></div>
                    <p class="mt-3 text-sm font-semibold text-slate-900">No volunteers found</p>
                    <p class="mt-1 text-sm text-slate-500">Try adjusting your filters or search.</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <%= render "shared/pagination", pagy: @pagy %>
      </div>

      <%# Mobile cards (below md) — read-only info; bulk assignment is a desktop tool %>
      <div class="space-y-3 md:hidden">
        <% if @volunteers.any? %>
          <% @volunteers.each do |volunteer| %>
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <%= link_to formatted_name(volunteer.display_name).presence || volunteer.email, edit_volunteer_path(volunteer), class: "text-base font-semibold #{name_link_class}" %>
                <span class="<%= pill %> <%= volunteer.active? ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-600" %>"><%= volunteer.active? ? "Active" : "Inactive" %></span>
              </div>
              <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-3">
                <div><dt class="text-xs text-slate-500">Email</dt><dd class="mt-0.5 truncate text-sm text-slate-700"><%= volunteer.email %></dd></div>
                <div><dt class="text-xs text-slate-500">Supervisor</dt><dd class="mt-0.5 text-sm text-slate-700"><%= volunteer.supervisor_name.present? ? formatted_name(volunteer.supervisor_name) : tag.span("\u2014", class: "text-slate-500") %></dd></div>
                <div><dt class="text-xs text-slate-500">Transition-aged youth</dt><dd class="mt-0.5"><% if volunteer.has_transition_aged_youth_cases %><span class="<%= pill %> bg-violet-50 text-violet-700">Yes</span><% else %><span class="text-sm text-slate-500">No</span><% end %></dd></div>
                <div><dt class="text-xs text-slate-500">Cases</dt><dd class="mt-0.5 text-sm text-slate-700"><%= safe_join(volunteer.casa_cases.map { |cc| link_to cc.case_number, casa_case_path(cc), class: "text-brand-600 hover:text-brand-700" }, ", ").presence || tag.span("\u2014", class: "text-slate-500") %></dd></div>
              </dl>
              <div class="mt-3 flex flex-wrap items-center gap-1">
                <%= link_to edit_volunteer_path(volunteer), class: ghost_class do %><i class="bi bi-pencil" aria-hidden="true"></i> Edit<% end %>
                <% if policy(volunteer).impersonate? %>
                  <%= link_to impersonate_volunteer_path(volunteer), class: ghost_class do %><i class="bi bi-person-badge" aria-hidden="true"></i> Impersonate<% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="rounded-2xl border border-slate-200 bg-white px-4 py-14 text-center">
            <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-people text-xl" aria-hidden="true"></i></div>
            <p class="mt-3 text-sm font-semibold text-slate-900">No volunteers found</p>
            <p class="mt-1 text-sm text-slate-500">Try adjusting your filters or search.</p>
          </div>
        <% end %>
      </div>

      <%# Bulk supervisor-assignment modal (native dialog, opened by the Manage Volunteers button) %>
      <dialog data-modal-target="dialog" aria-labelledby="bulk-modal-title" class="w-[calc(100vw-2rem)] max-w-md overflow-hidden rounded-2xl p-0 shadow-xl backdrop:bg-slate-900/40">
        <div class="flex items-center gap-3 border-b border-slate-100 px-5 py-4">
          <h2 id="bulk-modal-title" class="flex-1 text-base font-semibold text-slate-900">Assign a supervisor</h2>
          <button type="button" data-action="modal#close" aria-label="Close" class="grid h-8 w-8 place-items-center rounded-lg text-slate-500 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"><i class="bi bi-x-lg" aria-hidden="true"></i></button>
        </div>
        <div class="px-5 py-4">
          <label for="supervisor_volunteer_supervisor_id" class="mb-1.5 block text-sm font-medium text-slate-700">Choose a supervisor to reassign the selected volunteers.</label>
          <div class="relative">
            <select name="supervisor_volunteer[supervisor_id]" id="supervisor_volunteer_supervisor_id" required data-disable-form-target="input" data-action="disable-form#validate" class="block w-full appearance-none rounded-lg border border-slate-300 bg-white py-2.5 pl-3.5 pr-9 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none">
              <option value="unselected">Choose a supervisor</option>
              <option value="">None</option>
              <% @supervisors.each do |supervisor| %>
                <option value="<%= supervisor.id %>"><%= formatted_name(supervisor.display_name) %></option>
              <% end %>
            </select>
            <i class="bi bi-chevron-down pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-500" aria-hidden="true"></i>
          </div>
        </div>
        <div class="flex items-center justify-end gap-2 border-t border-slate-100 px-5 py-4">
          <button type="button" data-action="modal#close" class="<%= button_classes(:secondary) %>">Cancel</button>
          <%= form.button "Confirm", type: :submit, disabled: true, data: {"disable-form-target": "submitButton"}, class: button_classes(:primary) %>
        </div>
      </dialog>
    <% end %>
  </div>

  <% if @volunteers.any? %>
    <div class="md:hidden"><%= render "shared/pagination", pagy: @pagy %></div>
  <% end %>
</div>
