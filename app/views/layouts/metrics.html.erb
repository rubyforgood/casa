<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:page_title) ? yield(:page_title) : "Health" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "metrics", defer: true %>
  </head>
  <body class="min-h-screen bg-slate-50 font-sans text-slate-900 antialiased">
    <%= yield %>
  </body>
</html>
