<% content_for :page_title, "Accept your invitation" %>
<% field = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>

<div class="mb-8">
  <h2 class="text-2xl font-bold tracking-tight text-slate-900">Set your password</h2>
  <p class="mt-2 text-sm text-slate-500">Welcome to CASA — choose a password to activate your account.</p>
</div>

<% if resource.errors.any? %>
  <div class="mb-5 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
    <ul class="list-inside list-disc space-y-1">
      <% resource.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: resource, as: resource_name, url: invitation_path(resource_name), local: true, html: {method: :put}, class: "space-y-5") do |f| %>
  <%= f.hidden_field :invitation_token, readonly: true %>

  <% if f.object.class.require_password_on_accepting %>
    <div>
      <%= f.label :password, class: "mb-1.5 block text-sm font-medium text-slate-700" %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", required: true, placeholder: "••••••••", class: field %>
    </div>
    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, placeholder: "••••••••", class: field %>
    </div>
  <% end %>

  <%= f.submit "Activate account", class: "w-full cursor-pointer rounded-lg bg-brand-600 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:ring-offset-2" %>
<% end %>
