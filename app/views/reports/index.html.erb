<% content_for :page_title, "Reports" %>
<%# reports#index (the reports hub) on the casa_app shell. Quick one-click CSV exports + a
    filterable Case Contacts Report builder. The submit buttons keep `.report-form-submit` +
    `data-disable-with` — src/reports.js intercepts the click, swaps the label to the disable-with
    text, and native-submits the form (so the CSV download bypasses Turbo); the leading icons are
    pointer-events-none so `event.target` is always the button. The four filter selects stay
    NATIVE `<select multiple>` with their spec-locked ids (multiple-select-field1..4) — select2
    is dropped (it would hide the native select and break `select .. from:` / `have_select`).
    The column filter is a native <details> (was a Bootstrap modal). Several headings/labels +
    button names are Title Case and spec-locked; kept verbatim, queued for the sentence-case sweep. %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% section_title = "text-lg font-semibold text-slate-900" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% multiselect_class = "block w-full rounded-lg border border-slate-300 bg-white p-2 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% radio_class = "h-4 w-4 border-slate-300 text-brand-600 focus:ring-brand-500" %>
<% check_class = "h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Reports</h1>
      <p class="mt-1 text-sm text-slate-500">Download CSV exports for your organization.</p>
    </div>

    <section class="<%= card %>">
      <h2 class="<%= section_title %>">Quick exports</h2>
      <p class="mt-1 text-sm text-slate-500">One-click CSV downloads.</p>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <% exports = [
          ["Mileage Report", "Downloading Mileage Report", mileage_reports_path(format: :csv), "bi-signpost-2"],
          ["Missing Data Report", "Downloading Missing Data Report", missing_data_reports_path(format: :csv), "bi-database"],
          ["Learning Hours Report", "Downloading Learning Hours Report", learning_hours_reports_path(format: :csv), "bi-hourglass-split"],
          ["Export Volunteers Emails", "Downloading Export Volunteers Emails", export_emails_path(format: :csv), "bi-envelope"],
          ["Followups Report", "Downloading Followups Report", followup_reports_path(format: :csv), "bi-check2-square"],
          ["Placements Report", "Downloading Placements Report", placement_reports_path(format: :csv), "bi-house-door"]
        ] %>
        <% exports.each do |label, feedback, url, icon| %>
          <%= form_with url: url, method: :get do %>
            <%= button_tag type: "submit", class: "report-form-submit #{button_classes(:secondary)} w-full", data: {disable_with: feedback} do %>
              <i class="bi <%= icon %> pointer-events-none" aria-hidden="true"></i> <%= label %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </section>

    <section class="<%= card %>">
      <h2 class="<%= section_title %>">Case Contacts Report</h2>
      <p class="mt-1 text-sm text-slate-500">A CSV of all fields for every volunteer's case contacts. Choose a date range and optional filters.</p>

      <%= form_with url: case_contact_reports_path(format: :csv), scope: "report", method: :get, local: true, class: "mt-5 space-y-5" do |f| %>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :start_date, "Start date", class: label_class %>
            <%= f.date_field :start_date, value: 6.months.ago, class: input_class %>
          </div>
          <div>
            <%= f.label :end_date, "End date", class: label_class %>
            <%= f.date_field :end_date, value: Date.today, class: input_class %>
          </div>
        </div>

        <% if current_user&.casa_admin? || current_user&.supervisor? %>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <%= f.label :supervisor_ids, "Assigned To", class: label_class %>
              <%= f.select :supervisor_ids, options_for_select(Supervisor.where(casa_org: current_user.casa_org).map { |s| [formatted_name(s.display_name), s.id] }), {include_hidden: false}, {id: "multiple-select-field1", multiple: true, size: 4, class: multiselect_class} %>
            </div>
            <div>
              <%= f.label :creator_ids, "Volunteers", class: label_class %>
              <%= f.select :creator_ids, options_for_select(Volunteer.where(casa_org: current_user.casa_org).map { |v| [formatted_name(v.display_name), v.id] }), {include_hidden: false}, {id: "multiple-select-field2", multiple: true, size: 4, class: multiselect_class} %>
            </div>
            <div>
              <%= f.label :contact_type_ids, "Contact Type", class: label_class %>
              <%= f.collection_select :contact_type_ids, ContactType.for_organization(current_user.casa_org), :id, :name, {include_hidden: false}, {id: "multiple-select-field3", multiple: true, size: 4, class: multiselect_class} %>
            </div>
            <div>
              <%= f.label :contact_type_group_ids, "Contact Type Group", class: label_class %>
              <%= f.collection_select :contact_type_group_ids, ContactTypeGroup.for_organization(current_user.casa_org), :id, :name, {include_hidden: false}, {id: "multiple-select-field4", multiple: true, size: 4, class: multiselect_class} %>
            </div>
          </div>
          <p class="text-xs text-slate-500">Hold Ctrl (Cmd on Mac) to select more than one.</p>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <% [["want_driving_reimbursement", "Want driving reimbursement"], ["contact_made", "Contact made"], ["has_transitioned", "Transition-aged youth"]].each do |field, heading| %>
              <fieldset class="m-0 border-0 p-0">
                <legend class="<%= label_class %>"><%= heading %></legend>
                <div class="space-y-1.5">
                  <%= f.collection_radio_buttons field.to_sym, boolean_choices, :last, :first do |b| %>
                    <div class="flex items-center gap-2">
                      <%= b.radio_button(class: radio_class) %>
                      <%= b.label(class: "text-sm text-slate-700") %>
                    </div>
                  <% end %>
                </div>
              </fieldset>
            <% end %>
          </div>
        <% end %>

        <details class="rounded-lg border border-slate-200">
          <summary class="flex cursor-pointer list-none items-center gap-2 px-4 py-3 text-sm font-medium text-slate-700 [&::-webkit-details-marker]:hidden">
            <i class="bi bi-funnel" aria-hidden="true"></i> Filter columns
          </summary>
          <div class="border-t border-slate-100 px-4 py-4">
            <p class="mb-3 text-xs text-slate-500">All columns are exported by default. Uncheck any you want to omit.</p>
            <%= f.fields_for :filtered_csv_cols do |ff| %>
              <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                <% CaseContactReport::COLUMNS.each do |column| %>
                  <label class="flex items-center gap-2 text-sm text-slate-700">
                    <%= ff.check_box column, {checked: true, class: check_class}, true, false %>
                    <%= column.to_s.titleize %>
                  </label>
                <% end %>
              </div>
            <% end %>
          </div>
        </details>

        <div>
          <%= button_tag type: "submit", class: "report-form-submit #{button_classes(:primary)}", data: {disable_with: "Downloading Report"} do %>
            <i class="bi bi-download pointer-events-none" aria-hidden="true"></i> Download Report
          <% end %>
        </div>
      <% end %>
    </section>
  </div>
</div>
