<%# Org-settings Sent Emails list (casa_app; rendered only by casa_org/edit). Cell content +
    the id/time format are locked by the view spec; only the wrapper/table styling changed. %>
<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <h3 class="text-base font-semibold text-slate-900">Sent Emails</h3>
  <div class="mt-4 overflow-x-auto">
    <table id="sent-emails" class="min-w-full divide-y divide-slate-200">
      <thead>
        <tr>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Mailer Type</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Category</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Recipient</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Time Sent</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @sent_emails.each do |sent_email| %>
          <tr id="email-<%= sent_email.id %>">
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= sent_email.mailer_type %></td>
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= sent_email.category %></td>
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= formatted_name(sent_email.user.display_name) %> &lt;<%= sent_email.sent_address %>&gt;</td>
            <td class="px-3 py-2.5 text-sm text-slate-500"><%= to_user_timezone(sent_email.created_at).strftime("%l:%M%P %d %b %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
