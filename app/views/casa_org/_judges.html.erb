<%# Org-settings Judges list (casa_app; rendered only by casa_org/edit). %>
<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h3 class="text-base font-semibold text-slate-900">Judge</h3>
    <%= link_to new_judge_path, class: button_classes(:secondary) do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i> New Judge
    <% end %>
  </div>
  <div class="mt-4 overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200">
      <thead>
        <tr>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Active?</th>
          <th scope="col" class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @judges.each do |judge| %>
          <tr id="judge-<%= judge.id %>">
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= judge.name %></td>
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= judge.active ? "Yes" : "No" %></td>
            <td class="px-3 py-2.5 text-right text-sm"><%= link_to "Edit", edit_judge_path(judge), class: "font-medium text-brand-600 hover:text-brand-700" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
