<%# Org-settings Contact Types list (casa_app; rendered only by casa_org/edit). %>
<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h3 class="text-base font-semibold text-slate-900">Contact types</h3>
    <%= link_to new_contact_type_path, class: button_classes(:secondary) do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i> New Contact Type
    <% end %>
  </div>
  <div class="mt-4 hidden overflow-x-auto md:block">
    <table id="contact-types" class="min-w-full divide-y divide-slate-200">
      <thead>
        <tr>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Name</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Group</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Active?</th>
          <th scope="col" class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% contact_types.each do |contact_type| %>
          <tr id="contact_type-<%= contact_type.id %>">
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= contact_type.name %></td>
            <td class="px-3 py-2.5 text-sm text-slate-500"><%= contact_type.contact_type_group.name %></td>
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= contact_type.active? ? "Yes" : "No" %></td>
            <td class="px-3 py-2.5 text-right text-sm"><%= link_to "Edit", edit_contact_type_path(contact_type), class: "font-medium text-brand-600 hover:text-brand-700" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4 space-y-3 md:hidden">
    <% contact_types.each do |contact_type| %>
      <div class="rounded-xl border border-slate-200 p-4">
        <p class="break-words font-medium text-slate-800"><%= contact_type.name %></p>
        <dl class="mt-2 space-y-1 text-sm">
          <div class="flex justify-between gap-3">
            <dt class="text-slate-500">Group</dt>
            <dd class="text-right text-slate-500"><%= contact_type.contact_type_group.name %></dd>
          </div>
          <div class="flex justify-between gap-3">
            <dt class="text-slate-500">Active?</dt>
            <dd class="text-right text-slate-700"><%= contact_type.active? ? "Yes" : "No" %></dd>
          </div>
        </dl>
        <div class="mt-3 border-t border-slate-100 pt-3 text-sm">
          <%= link_to "Edit", edit_contact_type_path(contact_type), class: "font-medium text-brand-600 hover:text-brand-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
