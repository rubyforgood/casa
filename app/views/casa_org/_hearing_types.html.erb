<%# Org-settings Hearing Types list (casa_app; rendered only by casa_org/edit). %>
<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h3 class="text-base font-semibold text-slate-900">Hearing types</h3>
    <%= link_to new_hearing_type_path, class: button_classes(:secondary) do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i> New hearing type
    <% end %>
  </div>
  <div class="mt-4 hidden overflow-x-auto md:block">
    <table id="hearing-types" class="min-w-full divide-y divide-slate-200">
      <thead>
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Name</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Checklist</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Active?</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-semibold text-slate-600 align-top">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @hearing_types.each do |hearing_type| %>
          <tr id="hearing_type-<%= hearing_type.id %>">
            <td class="px-4 py-3 text-sm text-slate-700"><%= hearing_type.name %></td>
            <td class="px-4 py-3 text-sm text-slate-500"><%= hearing_type.checklist_updated_date %></td>
            <td class="px-4 py-3 text-sm text-slate-700"><%= hearing_type.active ? "Yes" : "No" %></td>
            <td class="px-4 py-3 text-right text-sm"><%= link_to "Edit", edit_hearing_type_path(hearing_type), class: "font-medium text-brand-600 hover:text-brand-700" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4 space-y-3 md:hidden">
    <% @hearing_types.each do |hearing_type| %>
      <div class="rounded-xl border border-slate-200 p-4">
        <p class="break-words font-medium text-slate-800"><%= hearing_type.name %></p>
        <dl class="mt-2 space-y-1 text-sm">
          <div class="flex justify-between gap-3">
            <dt class="text-slate-500">Checklist</dt>
            <dd class="text-right text-slate-500"><%= hearing_type.checklist_updated_date.presence || "\u2014" %></dd>
          </div>
          <div class="flex justify-between gap-3">
            <dt class="text-slate-500">Active?</dt>
            <dd class="text-right text-slate-700"><%= hearing_type.active ? "Yes" : "No" %></dd>
          </div>
        </dl>
        <div class="mt-3 border-t border-slate-100 pt-3 text-sm">
          <%= link_to "Edit", edit_hearing_type_path(hearing_type), class: "font-medium text-brand-600 hover:text-brand-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
