<%# Org-settings Contact Topics list (casa_app; rendered only by casa_org/edit). Delete moved
    from the Bootstrap dropdown + Modal:: to a Dialog confirm-button (shared/confirm_button). %>
<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h3 class="text-base font-semibold text-slate-900">Contact Topics</h3>
    <%= link_to new_contact_topic_path, class: button_classes(:secondary) do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i> New contact topic
    <% end %>
  </div>
  <div class="mt-4 hidden overflow-x-auto md:block">
    <table id="contact-topics" class="min-w-full divide-y divide-slate-200">
      <thead>
        <tr>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Question</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Details</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Active?</th>
          <th scope="col" class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @contact_topics.each do |contact_topic| %>
          <tr id="contact_topic-<%= contact_topic.id %>">
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= contact_topic.question %></td>
            <td class="whitespace-pre-line px-3 py-2.5 text-sm text-slate-500"><%= contact_topic.details %></td>
            <td class="px-3 py-2.5 text-sm text-slate-700"><%= contact_topic.active ? "Yes" : "No" %></td>
            <td class="px-3 py-2.5 text-right text-sm">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Edit", edit_contact_topic_path(contact_topic), class: "font-medium text-brand-600 hover:text-brand-700" %>
                <%= render "shared/confirm_button", url: soft_delete_contact_topic_path(contact_topic), method: :delete, title: "Delete Contact Topic?", message: "This topic and its related questions will be deleted and will no longer be presented while filling out case contacts. This will not affect case contacts that have already been created.", confirm_label: "Delete Court Report Topic", trigger_label: "Delete", trigger_class: "font-medium text-rose-600 hover:text-rose-700" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4 space-y-3 md:hidden">
    <% @contact_topics.each do |contact_topic| %>
      <div class="rounded-xl border border-slate-200 p-4">
        <p class="break-words font-medium text-slate-800"><%= contact_topic.question %></p>
        <dl class="mt-2 space-y-1 text-sm">
          <div>
            <dt class="text-slate-500">Details</dt>
            <dd class="mt-0.5 whitespace-pre-line text-slate-700"><%= contact_topic.details %></dd>
          </div>
          <div class="flex justify-between gap-3">
            <dt class="text-slate-500">Active?</dt>
            <dd class="text-right text-slate-700"><%= contact_topic.active ? "Yes" : "No" %></dd>
          </div>
        </dl>
        <div class="mt-3 flex items-center gap-4 border-t border-slate-100 pt-3 text-sm">
          <%= link_to "Edit", edit_contact_topic_path(contact_topic), class: "font-medium text-brand-600 hover:text-brand-700" %>
          <%= render "shared/confirm_button", url: soft_delete_contact_topic_path(contact_topic), method: :delete, title: "Delete Contact Topic?", message: "This topic and its related questions will be deleted and will no longer be presented while filling out case contacts. This will not affect case contacts that have already been created.", confirm_label: "Delete Court Report Topic", trigger_label: "Delete", trigger_class: "font-medium text-rose-600 hover:text-rose-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
