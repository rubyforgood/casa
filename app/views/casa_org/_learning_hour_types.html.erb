<%# Org-settings Type of Learning list (casa_app; rendered only by casa_org/edit). %>
<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h3 class="text-base font-semibold text-slate-900">Type of learning</h3>
    <%= link_to new_learning_hour_type_path, class: button_classes(:secondary) do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i> New type of learning
    <% end %>
  </div>
  <div class="mt-4 hidden overflow-x-auto md:block">
    <table class="min-w-full divide-y divide-slate-200">
      <thead>
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Name</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 align-top">Active?</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-semibold text-slate-600 align-top">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @learning_hour_types.each do |learning_hour_type| %>
          <tr id="learning_hour_type-<%= learning_hour_type.id %>">
            <td class="px-4 py-3 text-sm text-slate-700 align-top"><%= learning_hour_type.name %></td>
            <td class="px-4 py-3 text-sm text-slate-700 align-top"><%= learning_hour_type.active ? "Yes" : "No" %></td>
            <td class="px-4 py-3 text-right align-top text-sm"><%= link_to "Edit", edit_learning_hour_type_path(learning_hour_type), class: "font-medium text-brand-600 hover:text-brand-700" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4 space-y-3 md:hidden">
    <% @learning_hour_types.each do |learning_hour_type| %>
      <div class="rounded-xl border border-slate-200 p-4">
        <p class="break-words font-medium text-slate-800"><%= learning_hour_type.name %></p>
        <dl class="mt-2 space-y-1 text-sm">
          <div class="flex justify-between gap-3">
            <dt class="text-slate-500">Active?</dt>
            <dd class="text-right text-slate-700"><%= learning_hour_type.active ? "Yes" : "No" %></dd>
          </div>
        </dl>
        <div class="mt-3 border-t border-slate-100 pt-3 text-sm">
          <%= link_to "Edit", edit_learning_hour_type_path(learning_hour_type), class: "font-medium text-brand-600 hover:text-brand-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
