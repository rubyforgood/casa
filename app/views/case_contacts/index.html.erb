<% content_for :page_title, "Case contacts" %>
<%# case_contacts#index on casa_app. Keeps filterrific (the .filter-form auto-submits on
    .filter-input change; the form targets the :case_contacts turbo-frame). The Bootstrap
    collapse is replaced by the `disclosure` controller: the panel is always in the DOM (so
    rack_test finds "Other filters" regardless) but starts `hidden` unless expand_filters?, so
    JS users see it collapsed. Cards are grouped by case; _case_contact is the shared card. %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% select_class = "filter-input block w-full appearance-none rounded-lg border border-slate-300 bg-white py-2.5 pl-3.5 pr-9 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% input_class = "filter-input block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% chevron = "bi bi-chevron-down pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-500" %>
<% check_class = "h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500 filter-input" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Case contacts</h1>
    <%= link_to new_case_contact_path, class: button_classes(:primary) do %><i class="bi bi-plus-lg" aria-hidden="true"></i> New Case Contact<% end %>
  </div>

  <%= form_for_filterrific @filterrific, url: case_contacts_path, html: {class: "filter-form mb-6"}, remote: true,
    data: {turbo: true, turbo_frame: :case_contacts, turbo_action: :advance} do |f| %>
    <%= hidden_field_tag "casa_case_id", params[:casa_case_id] %>

    <div data-controller="disclosure" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold text-slate-900">Filter by</h2>
        <button type="button" data-action="disclosure#toggle" data-disclosure-target="trigger" aria-expanded="<%= expand_filters? %>" aria-controls="filter-card-body" class="inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
          Expand / Hide <i class="bi bi-chevron-down text-xs" aria-hidden="true"></i>
        </button>
      </div>

      <div class="mt-4 flex flex-wrap items-end justify-between gap-4">
        <div class="flex flex-wrap items-end gap-4">
          <div class="min-w-[12rem]">
            <%= f.label :sorted_by, class: label_class %>
            <div class="relative">
              <%= f.select(:sorted_by, @filterrific.select_options[:sorted_by], {}, {class: select_class}) %>
              <i class="<%= chevron %>" aria-hidden="true"></i>
            </div>
          </div>
          <label class="inline-flex items-center gap-2 pb-2.5 text-sm text-slate-700">
            <%= f.check_box :no_drafts, class: check_class %>
            Hide drafts
          </label>
        </div>
        <%= link_to "Reset filters", reset_filterrific_url, class: button_classes(:secondary),
          data: {turbo: true, turbo_frame: :case_contacts, turbo_action: :advance} %>
      </div>

      <div id="filter-card-body" data-disclosure-target="panel" class="<%= "hidden" unless expand_filters? %> mt-5 space-y-5 border-t border-slate-100 pt-5">
        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">Date of contact</h3>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <%= f.label "Starting from", for: "filterrific_occurred_starting_at", class: label_class %>
              <%= f.date_field(:occurred_starting_at, class: input_class) %>
            </div>
            <div>
              <%= f.label "Ending at", for: "filterrific_occurred_ending_at", class: label_class %>
              <%= f.date_field(:occurred_ending_at, class: input_class) %>
            </div>
          </div>
        </div>

        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">Contact types</h3>
          <div id="contact-type-form" class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2 lg:grid-cols-3">
            <% @current_organization_groups.each do |group| %>
              <div>
                <h4 class="mb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500"><%= group.name %></h4>
                <div class="space-y-1.5">
                  <% group.contact_types.each do |contact_type| %>
                    <label class="flex items-center gap-2 text-sm text-slate-700">
                      <%= f.check_box :contact_type, {multiple: true, class: check_class}, contact_type.id, nil %>
                      <%= contact_type.name %>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">Other filters</h3>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div>
              <%= f.label :contact_medium, class: label_class %>
              <div class="relative">
                <%= f.select(:contact_medium, options_from_collection_for_select(contact_mediums, "value", "label"), {include_blank: "Display all", class: select_class}) %>
                <i class="<%= chevron %>" aria-hidden="true"></i>
              </div>
            </div>
            <div>
              <%= f.label :want_driving_reimbursement, class: label_class %>
              <div class="relative">
                <%= f.select(:want_driving_reimbursement, @case_contacts.boolean_select_options, {include_blank: "Display all", class: select_class}) %>
                <i class="<%= chevron %>" aria-hidden="true"></i>
              </div>
            </div>
            <div>
              <%= f.label :contact_made, class: label_class %>
              <div class="relative">
                <%= f.select(:contact_made, @case_contacts.boolean_select_options, {include_blank: "Display all", class: select_class}) %>
                <i class="<%= chevron %>" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag :case_contacts do %>
    <% @case_contacts.object.each do |casa_case_id, data| %>
      <section class="mb-6">
        <h2 class="mb-3 text-lg font-semibold text-slate-900"><%= @case_contacts.display_case_number(casa_case_id) %></h2>
        <div class="space-y-4">
          <%= render partial: "case_contacts/case_contact", collection: data, as: :contact %>
        </div>
      </section>
    <% end %>

    <% if @case_contacts.object.empty? %>
      <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
        <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-slate-100 text-slate-400"><i class="bi bi-chat-square-text text-xl" aria-hidden="true"></i></div>
        <p class="mt-3 text-sm text-slate-500">
          <% if params.key?(:casa_case_id) %><%= @case_contacts.display_case_number(params[:casa_case_id].to_i) %> &mdash; <% end %><%= params[:filterrific] ? "No case contacts have been found." : "You have no case contacts for this case. Please click New Case Contact button above to create a case contact for your youth!" %>
        </p>
      </div>
    <% end %>

    <div class="mt-2"><%= render "shared/pagination", pagy: @pagy %></div>
  <% end %>
</div>
