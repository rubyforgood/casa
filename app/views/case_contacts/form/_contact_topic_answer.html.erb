<%# Nested topic-answer row for the case-contact form. casa-nested-form clones this from the
    <template>, so every hook must survive cloning: .nested-form-wrapper, the wrapper target,
    data-new-record/child-index, and the hidden id/_destroy fields. The select keeps
    .contact-topic-id-select + the case-contact-form onContactTopicSelect action/target; the
    textarea keeps .contact-topic-answer-input + autosave. Native-select chevron per design.md. %>
<div class="nested-form-wrapper rounded-xl border border-slate-200 bg-slate-50 p-4"
  data-new-record="<%= form.object.new_record? %>"
  data-casa-nested-form-target="wrapper"
  data-child-index="<%= form.options[:child_index] %>">
  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :contact_topic_id, "Discussion Topic", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
      <div class="relative">
        <%= form.select(:contact_topic_id,
          select_options,
          {include_blank: "Select a discussion topic"},
          class: "contact-topic-id-select block w-full appearance-none rounded-lg border border-slate-300 bg-white py-2.5 pl-3.5 pr-9 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none",
          data: {
            action: "change->case-contact-form#onContactTopicSelect",
            case_contact_form_target: "contactTopicSelect"
          }
        ) %>
        <i class="bi bi-chevron-down pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-500" aria-hidden="true"></i>
      </div>
    </div>
    <div>
      <%= form.label :value, "Discussion Notes", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
      <%= form.text_area(:value,
        data: {action: "input->autosave#save"},
        rows: 3,
        class: "contact-topic-answer-input block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none",
        placeholder: "Enter discussion notes here to be included in the court report. Refer to individuals by role, not by name."
      ) %>
    </div>
  </div>
  <div class="mt-3 flex justify-end">
    <button type="button"
      data-action="casa-nested-form#confirmDestroyAndRemove"
      class="<%= button_classes(:danger_outline) %>">
      Delete
    </button>
  </div>
  <%= form.hidden_field(:id, value: form.object.id) %>
  <%= form.hidden_field :_destroy %>
</div>
