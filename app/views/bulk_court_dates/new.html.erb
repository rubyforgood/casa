<% content_for :page_title, "New bulk court date" %>
<%# bulk_court_dates#new on casa_app: pick a case group, then the same court-date fields as a
    single court date; on submit one court date is created for every case in the group. Reuses
    court_dates/_fields (casa_case nil -> the copy-from-sibling block stays off). %>
<% card = "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<% select_class = "block w-full appearance-none rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 pr-9 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">New bulk court date</h1>
    <div class="<%= card %>">
      <%= form_with(model: @court_date, url: bulk_court_dates_path, method: :post, local: true,
            data: {controller: "court-order-form", nested_form_wrapper_selector_value: ".nested-form-wrapper"}, class: "space-y-6") do |form| %>
        <%= render "shared/form_errors", resource: @court_date %>
        <h6 class="text-sm text-slate-500">Create a court date for all cases in a group.</h6>
        <div>
          <%= form.label :case_group_id, "Case group", class: label_class %>
          <div class="relative">
            <%= form.collection_select(:case_group_id, current_organization.case_groups, :id, :name, {include_hidden: false, include_blank: "-Select case group-"}, {class: select_class}) %>
            <i class="bi bi-chevron-down pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-xs text-slate-500" aria-hidden="true"></i>
          </div>
        </div>
        <%= render "court_dates/fields", court_date: @court_date, form: form, casa_case: nil %>
        <div class="top-page-actions border-t border-slate-100 pt-5">
          <%= button_tag type: "submit", class: button_classes(:primary) do %>
            <% if @court_date.persisted? %>
              <i class="bi bi-check-lg" aria-hidden="true"></i> Update
            <% else %>
              <i class="bi bi-plus-lg" aria-hidden="true"></i> Create
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
