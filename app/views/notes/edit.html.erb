<% content_for :page_title, "Edit note" %>
<%# notes#edit on casa_app. A single volunteer note (admins/supervisors only); on save the
    controller redirects back to the volunteer edit page. `note[content]` + the "Update note"
    button are spec-locked. Note has no validations, so there is no failure re-render. %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl space-y-6">
    <div>
      <%= link_to edit_volunteer_path(@volunteer), class: "inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-slate-700" do %>
        <i class="bi bi-chevron-left text-xs" aria-hidden="true"></i> Back to volunteer
      <% end %>
    </div>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Update volunteer note</h1>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
      <%= form_with model: @note, url: volunteer_note_path(@volunteer, @note) do |form| %>
        <%= form.label :content, "Note", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
        <%= form.text_area :content, rows: 5, placeholder: "Enter a note regarding the volunteer. These notes are only visible to CASA administrators and supervisors.", class: input_class %>
        <div class="actions mt-4">
          <%= form.button type: "submit", id: "note-submit", class: button_classes(:primary) do %>
            <i class="bi bi-save" aria-hidden="true"></i> Update note
          <% end %>
        </div>
      <% end %>
    </section>
  </div>
</div>
