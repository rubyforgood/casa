<%# Court report generator (index). A Dialog (design-system) + the court-report Stimulus
    controller (reused from the case-show modal) that posts the case + date range to the JSON
    generate endpoint, shows a spinner, then opens the docx download. The case picker is a
    searchable single-select TomSelect (searchable-select) — its text search covers the volunteer
    names embedded in the option labels. Spec-locked ids kept: #generate-docx-report-modal,
    #case-selection, #btnGenerateReport, #start_date, #end_date, #spinner, #user-time-zone. %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% label_class = "mb-1.5 block text-sm font-medium text-slate-700" %>
<%= render Dialog::GroupComponent.new(id: "generate-docx-report-modal", label: "Download Court Report as a .docx", controllers: "court-report") do |dialog| %>
  <% dialog.with_trigger do %>
    <%= tag.button type: "button", data: {action: "modal#open"}, class: button_classes(:primary) do %>
      <i class="bi bi-file-earmark-word" aria-hidden="true"></i> Download Court Report as .docx
    <% end %>
  <% end %>
  <%= form_with url: generate_case_court_reports_path, local: false, data: {court_report_target: "form"} do |form| %>
    <%= render Dialog::HeaderComponent.new(title: "Download Court Report as a .docx") %>
    <%= render Dialog::BodyComponent.new(classes: "space-y-4") do %>
      <p class="text-sm text-slate-600">To download a court report, choose an active case and specify the date range.</p>
      <div data-court-report-target="error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-700" role="alert"></div>
      <div>
        <label for="case-selection" class="<%= label_class %>">Case</label>
        <% select_options = @assigned_cases.map { |casa_case| casa_case.decorate.court_report_select_option } %>
        <%= select_tag :case_number, options_for_select(select_options), prompt: "Select case number", include_blank: false, id: "case-selection", data: {controller: "searchable-select"}, class: input_class %>
      </div>
      <%= form.hidden_field :time_zone, id: "user-time-zone", data: {court_report_target: "timeZone"} %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :start_date, "Starting from", class: label_class %>
          <%= form.date_field :start_date, id: "start_date", value: Date.current, class: input_class %>
        </div>
        <div>
          <%= form.label :end_date, "Ending at", class: label_class %>
          <%= form.date_field :end_date, id: "end_date", value: Date.current, class: input_class %>
        </div>
      </div>
    <% end %>
    <%= render Dialog::FooterComponent.new do %>
      <button type="button" data-action="modal#close" class="<%= button_classes(:secondary) %>">Cancel</button>
      <button type="submit" id="btnGenerateReport" data-action="court-report#generate" data-court-report-target="submit" class="<%= button_classes(:primary) %>">
        <i id="spinner" class="bi bi-arrow-repeat hidden animate-spin" data-court-report-target="spinner" aria-hidden="true"></i>
        <i class="bi bi-download" aria-hidden="true"></i> Generate Report
      </button>
    <% end %>
  <% end %>
<% end %>
