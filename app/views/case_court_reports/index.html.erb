<% content_for :page_title, "Generate reports" %>
<%# case_court_reports#index on the casa_app shell. Pick any assigned case + a date range and
    generate a docx (the court-report Stimulus controller, reused from the case-show modal).
    Role-based case visibility is server-side (@assigned_cases). The `card-style` class is inert
    on Tailwind but kept for the view spec. %>
<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Generate reports</h1>
      <p class="mt-1 text-sm text-slate-500">Generate a pre-filled court report for one of your cases.</p>
    </div>
    <div class="card-style rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
      <h6 class="text-base font-semibold text-slate-900">Court Reports</h6>
      <p class="mt-1 text-sm text-slate-500">The court report is pre-filled with information for your case. Choose from your active cases; the document is Microsoft Word (.docx).</p>
      <div class="mt-4">
        <%= render "case_court_reports/generate_docx" %>
      </div>
    </div>
  </div>
</div>
