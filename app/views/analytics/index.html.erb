<% content_for :page_title, "Analytics" %>
<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Analytics</h1>
    <p class="mt-1 text-sm text-slate-500">Your chapter's activity and data quality. Hover a chart for details.</p>

    <%# KPI stat cards -- same markup token as the admin dashboard cards (design.md > KPI stat
        card). Contacts leads with its month-over-month delta as a colored meta line; "cases
        needing contact" mirrors the dashboard's amber attention treatment (amber icon tile,
        slate number, 14-day meta). %>
    <% k = @kpis %>
    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-brand-50 text-brand-600"><i class="bi bi-chat-square-text" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= k[:contacts_this_month] %></div>
        <div class="text-sm text-slate-500">Contacts this month</div>
        <% d = k[:contacts_delta] %>
        <div class="mt-1 text-xs font-medium <%= (d > 0) ? "text-emerald-600" : ((d < 0) ? "text-rose-600" : "text-slate-500") %>">
          <% if d > 0 %><i class="bi bi-arrow-up-short" aria-hidden="true"></i>+<%= d %> vs last month<% elsif d < 0 %><i class="bi bi-arrow-down-short" aria-hidden="true"></i><%= d %> vs last month<% else %>No change vs last month<% end %>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-sky-50 text-sky-600"><i class="bi bi-people" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= k[:active_volunteers] %></div>
        <div class="text-sm text-slate-500">Active volunteers</div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <span class="grid h-9 w-9 place-items-center rounded-xl <%= k[:cases_needing_contact].positive? ? "bg-amber-50 text-amber-600" : "bg-emerald-50 text-emerald-600" %>"><i class="bi <%= k[:cases_needing_contact].positive? ? "bi-clock-history" : "bi-check2-circle" %>" aria-hidden="true"></i></span>
        <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= k[:cases_needing_contact] %></div>
        <div class="text-sm text-slate-500">Cases needing contact</div>
        <div class="mt-1 text-xs text-slate-500">Not contacted in <%= k[:followup_days] %>+ days</div>
      </div>
    </div>

    <%= render "metrics/dashboard", cc: @case_contacts, heatmap: @contact_heatmap, au: @active_users, range: @range, base_path: analytics_path %>
  </div>
</div>
