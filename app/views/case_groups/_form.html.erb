<% content_for :page_title, case_group.persisted? ? "Edit case group" : "New case group" %>
<% input_class = "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 focus:outline-none" %>
<% btn_primary = button_classes(:primary) %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl">
    <div class="mb-6">
      <p class="text-sm font-medium text-brand-600"><%= link_to "Case groups", case_groups_path, class: "hover:text-brand-700" %></p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight text-slate-900"><%= case_group.persisted? ? "Edit case group" : "New case group" %></h1>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
      <%= form_with model: case_group do |form| %>
        <%= render "shared/form_errors", resource: case_group %>
        <div class="space-y-5">
          <div>
            <%= form.label :name, class: "mb-1.5 block text-sm font-medium text-slate-700" %>
            <%= form.text_field :name, required: true, class: input_class %>
          </div>

          <div data-controller="multiple-select">
            <%= form.label :casa_case_ids, "Cases", class: "mb-1.5 block text-sm font-medium text-slate-700" %>
            <%= form.select(
              :casa_case_ids,
              current_organization.casa_cases.map { |casa_case| ["#{casa_case.case_number} - #{casa_case.assigned_volunteers.map(&:display_name).join(", ").presence || "Unassigned"}", casa_case.id] },
              {include_hidden: false, autocomplete: "off"},
              {multiple: true, data: {"multiple-select-target": "select"}}
            ) %>
          </div>

          <div class="flex items-center gap-3">
            <%= button_tag(type: "submit", class: btn_primary) do %>
              <i class="bi bi-check-lg" aria-hidden="true"></i> Submit
            <% end %>
            <%= link_to "Cancel", case_groups_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
