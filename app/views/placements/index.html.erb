<% content_for :page_title, "Placement history" %>
<%# placements#index on the casa_app shell (nested under a case). Placement history for the youth,
    newest first; each row shows the placement type + the span it covered (from its start date to
    the next placement's start, or Present for the current one). Delete opens a native-dialog
    confirm (Dialog::) whose "Confirm" is a button_to DELETE. The non-:js destroy spec drives
    Delete -> "Delete placement?" -> Close/Confirm, all in the DOM. %>
<% card = "rounded-2xl border border-slate-200 bg-white shadow-sm" %>
<% th = "px-3 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500" %>
<% td = "px-3 py-3 text-sm text-slate-700 align-top" %>

<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-4xl">
    <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">
        Placement history for
        <%= link_to @casa_case.case_number, casa_case_path(@casa_case), class: "text-brand-600 hover:text-brand-700" %>
      </h1>
      <%= link_to new_casa_case_placement_path(@casa_case), class: button_classes(:primary) do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i> New placement
      <% end %>
    </div>

    <% if @placements.any? %>
      <div class="<%= card %> overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="<%= th %>">Placement type</th>
                <th scope="col" class="<%= th %>">Date</th>
                <th scope="col" class="<%= th %> text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @placements.each_with_index do |placement, idx| %>
                <tr>
                  <td class="<%= td %> font-medium text-slate-800"><%= placement.placement_type.name %></td>
                  <td class="<%= td %> whitespace-nowrap">
                    <%= placement.decorate.formatted_date %>
                    -
                    <% if idx.zero? %>
                      Present
                    <% elsif @placements[idx - 1].placement_started_at %>
                      <%= @placements[idx - 1].decorate.formatted_date %>
                    <% end %>
                  </td>
                  <td class="<%= td %> text-right">
                    <div class="inline-flex items-center gap-2">
                      <%= link_to edit_casa_case_placement_path(@casa_case, placement), class: button_classes(:secondary) do %>
                        <i class="bi bi-pencil" aria-hidden="true"></i> Edit
                      <% end %>
                      <%= render Dialog::GroupComponent.new(id: placement.id, label: "Delete placement?") do |dialog| %>
                        <% dialog.with_trigger do %>
                          <%= tag.button "Delete", type: "button", data: {action: "modal#open"}, class: button_classes(:danger_outline) %>
                        <% end %>
                        <%= render Dialog::HeaderComponent.new(title: "Delete placement?", icon: "bi bi-exclamation-triangle", variant: :danger) %>
                        <%= render Dialog::BodyComponent.new do %>
                          <p class="text-sm text-slate-600">This will permanently remove this placement from the case's history.</p>
                        <% end %>
                        <%= render Dialog::FooterComponent.new do %>
                          <button type="button" data-action="modal#close" class="<%= button_classes(:secondary) %>">Close</button>
                          <%= button_to "Confirm", casa_case_placement_path(@casa_case, placement), method: :delete, form_class: "contents", class: button_classes(:danger) %>
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="<%= card %> px-6 py-16 text-center">
        <div class="mx-auto mb-4 grid h-12 w-12 place-items-center rounded-full bg-slate-100 text-slate-400"><i class="bi bi-house-door text-xl" aria-hidden="true"></i></div>
        <h2 class="text-base font-semibold text-slate-900">No placements yet</h2>
        <p class="mt-1 text-sm text-slate-500">Add a placement to start this case's placement history.</p>
      </div>
    <% end %>
  </div>
</div>
